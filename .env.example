# ── Discord ──────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# v0.1.0 は single guild 前提。multi-guild は Phase 5 Deferred Scope (TBA)
DISCORD_GUILD_ID=
# Bot が応答するチャンネルID。カンマ区切りで複数指定可能
DISCORD_ALLOWED_CHANNELS=
# DM を許可する固定ユーザー ID（owner only）
DISCORD_DM_OWNER_USER_ID=YOUR_DISCORD_USER_ID

# ── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://grkd:grkd_dev@localhost:5432/grkd_jisho
# pg_dump custom-format backups (.dump). 0 disables retention pruning.
DB_BACKUP_DIR=./backups/postgres
DB_BACKUP_PREFIX=grkd-jisho
DB_BACKUP_RETENTION_DAYS=30

# ── LLM ──────────────────────────────────────────────────
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# ── Prompt ───────────────────────────────────────────────
PROMPT_VERSION=v1

# ── Bot Ops ──────────────────────────────────────────────
# lookup_logs と bot_events の保持日数 (30-365, デフォルト 90)
LOG_RETENTION_DAYS=90
# 1回の cache_refresh ジョブで削除可能な最大件数 (0=制限なし, デフォルト 100)
CACHE_REFRESH_MAX_ROWS=100

# ── Web UI (TOTP Auth) ───────────────────────────────────
# SESSION_SECRET は HMAC-SHA256 署名用。32文字以上のランダムな文字列
SESSION_SECRET=
# Cookie Secure 属性を明示制御（HTTPローカル環境は false、HTTPS本番は true）
# 未指定時は WEB_BASE_URL が https:// なら true、http:// なら false
SESSION_COOKIE_SECURE=
# 各種リンク生成に使う公開URL（http://localhost:4321 など）
WEB_BASE_URL=

# 初回ログイン:
#   1. http://<host>:4321/auth/setup を開く
#   2. 表示された QR コードを認証アプリでスキャン
#   3. 6桁コードを入力 → 管理画面へ
# 以降のログイン:
#   1. http://<host>:4321/auth/login を開く
#   2. 認証アプリの 6桁コードを入力
# リセット:
#   pnpm --filter @grkd-jisho/web auth:reset

# ── MCP Control Plane ────────────────────────────────────
# MCP agent の識別名（audit log に記録）
MCP_AGENT_ID=external-agent
# 読み取り専用モード（Level 1 only）
MCP_READONLY_MODE=true
# dry-run tools を有効にする（MCP_READONLY_MODE=false かつ MCP_ENABLE_DRY_RUN=true）
MCP_ENABLE_DRY_RUN=false
# Level 3 limited-write request tools を有効にする
MCP_ENABLE_LIMITED_WRITE=false
# MCP cache_refresh リクエスト1回あたりの最大削除件数（デフォルト 100）
MCP_MAX_CACHE_REFRESH_ROWS=100
