---
import "../styles/globals.css";
import { Sidebar } from "../components/admin/Sidebar";
import { TopBar } from "../components/admin/TopBar";

export interface Props {
  title: string;
  active: string;
}

const { title, active } = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — GRKD-Jisho Admin</title>
  </head>
  <body>
    <div class="app-shell">
      <Sidebar client:load active={active} />

      <div class="main-area">
        <TopBar client:load title={title} />

        <main class="content">
          <slot />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  .app-shell {
    display: flex;
    min-height: 100dvh;
    background: var(--color-porcelain-50);
  }

  .main-area {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .content {
    flex: 1;
    padding: 24px;
    max-width: 1680px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }
</style>
