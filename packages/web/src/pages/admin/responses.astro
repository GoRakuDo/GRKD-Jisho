---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { searchResponse, getOutputBucketLabel } from "@grkd-jisho/db";

const session = getSession(Astro);
const urlParams = new URL(Astro.url.toString()).searchParams;
const query = urlParams.get("query") ?? "";

let responses: Awaited<ReturnType<typeof searchResponse>> = [];

if (session?.isAdmin && query) {
  try {
    responses = await searchResponse(query, 20);
  } catch (err) {
    const reason = err instanceof Error ? err.message : String(err);
    console.error(`[Responses] SSR error: ${reason} → Check DB connection and response query parameters`);
  }
}
---

<AdminLayout title="Responses" active="responses">
  <div class="filter-bar">
    <form method="GET" action="/admin/responses" class="search-form">
      <input
        type="text"
        name="query"
        class="search-input"
        placeholder="Search by normalized query..."
        value={query}
      />
      <button type="submit" class="btn-primary">Search</button>
    </form>
  </div>

  {query && responses.length === 0 && (
    <div class="empty-state">
      <p>No responses found for "{query}".</p>
    </div>
  )}

  {responses.length > 0 && (
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>ID</th>
            <th>Query</th>
            <th>Output Bucket</th>
            <th>Manual</th>
            <th>Preview</th>
            <th>Updated</th>
          </tr>
        </thead>
        <tbody>
          {responses.map((r) => (
            <tr class="clickable-row" data-href={`/admin/responses/${r.id}`}>
              <td class="mono">{r.id}</td>
              <td>{r.query}</td>
              <td class="mono">{getOutputBucketLabel(r.roleKey)}</td>
              <td>
                {r.isManualOverride ? (
                  <span class="badge-manual">manual</span>
                ) : (
                  <span class="badge-auto">auto</span>
                )}
              </td>
              <td class="preview-cell">
                {r.responseText.length > 80
                  ? r.responseText.slice(0, 80) + "..."
                  : r.responseText}
              </td>
              <td class="mono">{r.updatedAt?.toLocaleString("en-US", { timeZone: "Asia/Jakarta" }) ?? "-"}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<script>
  document.addEventListener('click', (e) => {
    const row = (e.target as HTMLElement).closest('.clickable-row');
    if (row) {
      const href = row.getAttribute('data-href');
      if (href) window.location.href = href;
    }
  });
</script>

<style>
  .filter-bar {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 12px;
    margin-bottom: 20px;
  }

  .search-form {
    display: flex;
    gap: 8px;
  }

  .search-input {
    flex: 1;
    height: 40px;
    padding: 0 12px;
    background: var(--color-porcelain-50);
    border: 1px solid var(--color-graphite-300);
    border-radius: var(--radius-input);
    color: var(--color-graphite-900);
    font-size: 14px;
    font-family: var(--font-grkd-sans);
  }

  .search-input:focus {
    border-color: var(--color-royal-blue-600);
    outline: 3px solid var(--color-royal-blue-100);
    outline-offset: 0;
  }

  .btn-primary {
    background: var(--color-royal-blue-600);
    color: var(--color-porcelain-50);
    border: 1px solid var(--color-royal-blue-700);
    border-radius: var(--radius-button);
    padding: 0 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.1s;
  }

  .btn-primary:hover {
    background: var(--color-royal-blue-700);
  }

  .table-container {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    background: var(--color-porcelain-150);
    text-align: left;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table td {
    padding: 10px 12px;
    font-size: 13px;
    color: var(--color-graphite-650);
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--color-porcelain-150);
  }

  .clickable-row {
    cursor: pointer;
  }

  .mono {
    font-family: var(--font-grkd-mono);
    font-size: 12px;
  }

  .preview-cell {
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: var(--color-graphite-800);
  }

  .badge-manual {
    display: inline-block;
    background: var(--color-royal-blue-100);
    color: var(--color-royal-blue-700);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-auto {
    display: inline-block;
    background: var(--color-porcelain-150);
    color: var(--color-graphite-650);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .empty-state {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 40px;
    text-align: center;
    color: var(--color-graphite-500);
    font-size: 14px;
  }
</style>
