---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { getPendingJobs, getAllJobs } from "@grkd-jisho/db";
import { JobDetailPanel } from "../../components/admin/JobDetailPanel";
import { OpsJobsList } from "../../components/admin/OpsJobsList";

const session = getSession(Astro);

interface JobRecordDetail {
  id: string;
  jobType: string;
  status: string;
  approvalRequired: boolean;
  argsJson: Record<string, unknown>;
  resultJson: Record<string, unknown>;
  errorMessage: string | null;
  requestedBy: string;
  approvedBy: string | null;
  rejectedBy: string | null;
  createdAt: string | null;
  approvedAt: string | null;
  completedAt: string | null;
}

let pendingJobs: JobRecordDetail[] = [];
let recentJobs: JobRecordDetail[] = [];
const urlParams = new URL(Astro.url.toString()).searchParams;
const selectedJobId = urlParams.get("jobId") ?? "";
const currentFilter = urlParams.get("filter") ?? "";

if (session?.isAdmin) {
  try {
    const pending = await getPendingJobs();
    pendingJobs = pending.map((j) => ({
      ...j,
      createdAt: j.createdAt?.toISOString() ?? null,
      approvedAt: j.approvedAt?.toISOString() ?? null,
      completedAt: j.completedAt?.toISOString() ?? null,
      resultJson: j.resultJson ?? {},
    }));

    const all = await getAllJobs(50);
    recentJobs = all.map((j) => ({
      ...j,
      createdAt: j.createdAt?.toISOString() ?? null,
      approvedAt: j.approvedAt?.toISOString() ?? null,
      completedAt: j.completedAt?.toISOString() ?? null,
      resultJson: j.resultJson ?? {},
    }));
  } catch (err) {
    console.error("Ops jobs SSR error:", err);
  }
}

// Filter by status if filter param is set
const filteredJobs = currentFilter
  ? recentJobs.filter((j) => j.status === currentFilter)
  : recentJobs;

const selectedJob = recentJobs.find((j) => j.id === selectedJobId) ?? null;

const FILTERS = ["", "pending", "approved", "running", "succeeded", "failed", "rejected"];
const FILTER_LABELS: Record<string, string> = {
  "": "All",
  pending: "Pending",
  approved: "Approved",
  running: "Running",
  succeeded: "Succeeded",
  failed: "Failed",
  rejected: "Rejected",
};
---

<AdminLayout title="Ops Jobs" active="ops-jobs">
  <div class="section">
    <h2 class="section-title">Pending Approvals</h2>
    {pendingJobs.length === 0 && (
      <div class="empty-card">
        <p>No pending ops jobs. Agent requests that need approval will appear here.</p>
      </div>
    )}
    {pendingJobs.length > 0 && (
      <OpsJobsList client:load />
    )}
  </div>

  <div class="section">
    <h2 class="section-title">All Jobs</h2>

    <div class="filter-tabs">
      {FILTERS.map((f) => (
        <a
          href={`/admin/ops-jobs${f ? `?filter=${f}` : ""}`}
          class={`filter-tab ${currentFilter === f ? "active" : ""}`}
        >
          {FILTER_LABELS[f]}
        </a>
      ))}
    </div>

    <div class="job-layout">
      <div class="table-container">
        <table class="data-table">
          <thead>
            <tr>
              <th>Type</th>
              <th>Status</th>
              <th>ID</th>
              <th>Created</th>
            </tr>
          </thead>
          <tbody>
            {filteredJobs.map((j) => (
              <tr
                class={`clickable-row ${selectedJobId === j.id ? "selected" : ""}`}
                data-job-id={j.id}
              >
                <td class="job-type">{j.jobType}</td>
                <td>
                  <span class={`badge badge-${j.status}`}>{j.status}</span>
                </td>
                <td class="mono">{j.id}</td>
                <td class="mono">
                  {j.createdAt
                    ? new Date(j.createdAt).toLocaleString("en-US", { timeZone: "Asia/Jakarta" })
                    : "-"}
                </td>
              </tr>
            ))}
            {filteredJobs.length === 0 && (
              <tr>
                <td colspan="4" class="empty-cell">No jobs found for this filter.</td>
              </tr>
            )}
          </tbody>
        </table>
      </div>

      {selectedJob && (
        <JobDetailPanel job={selectedJob} />
      )}
    </div>
  </div>
</AdminLayout>

<script>
  // Table row click -> navigate with jobId
  document.addEventListener("click", (e) => {
    const row = (e.target as HTMLElement).closest(".clickable-row") as HTMLElement | null;
    if (row) {
      const jobId = row.getAttribute("data-job-id");
      if (jobId) {
        const url = new URL(window.location.href);
        url.searchParams.set("jobId", jobId);
        window.location.href = url.toString();
      }
    }
  });
</script>

<style>
  .section {
    margin-bottom: 32px;
  }

  .section-title {
    margin: 0 0 16px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .empty-card {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 40px;
    text-align: center;
    color: var(--color-graphite-500);
    font-size: 14px;
  }

  .filter-tabs {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
    background: var(--color-porcelain-150);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-input);
    padding: 4px;
    width: fit-content;
  }

  .filter-tab {
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--color-graphite-650);
    border-radius: 8px;
    text-decoration: none;
    transition: background 0.1s;
  }

  .filter-tab:hover {
    background: var(--color-porcelain-50);
  }

  .filter-tab.active {
    background: var(--color-royal-blue-600);
    color: var(--color-porcelain-50);
  }

  .job-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  .table-container {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    background: var(--color-porcelain-150);
    text-align: left;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table td {
    padding: 10px 12px;
    font-size: 13px;
    color: var(--color-graphite-650);
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--color-porcelain-150);
    cursor: pointer;
  }

  .data-table tbody tr.selected {
    background: var(--color-royal-blue-50);
    border-left: 3px solid var(--color-royal-blue-600);
  }

  .mono {
    font-family: var(--font-grkd-mono);
    font-size: 12px;
  }

  .job-type {
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .badge {
    display: inline-block;
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-pending { background: var(--color-warning-100); color: var(--color-warning-600); }
  .badge-approved { background: var(--color-success-100); color: var(--color-success-600); }
  .badge-running { background: var(--color-royal-blue-100); color: var(--color-royal-blue-700); }
  .badge-succeeded { background: var(--color-success-100); color: var(--color-success-600); }
  .badge-failed { background: var(--color-danger-100); color: var(--color-danger-600); }
  .badge-rejected { background: var(--color-porcelain-150); color: var(--color-graphite-650); }

  .empty-cell {
    text-align: center;
    color: var(--color-graphite-500);
    padding: 32px;
  }
</style>
