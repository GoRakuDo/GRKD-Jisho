---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { getCacheStats, getRecentCacheActivity, searchCacheEntries, getOutputBucketLabel } from "@grkd-jisho/db";
import { CacheDeletePanel } from "../../components/admin/CacheDeletePanel";
import { generateCsrfToken } from "../../lib/csrf";

const session = getSession(Astro);
const csrfToken = session ? generateCsrfToken(session.discordUserId) : '';
const urlParams = new URL(Astro.url.toString()).searchParams;
const query = urlParams.get("query") ?? "";

let total = 0;
let manualOverride = 0;
let deletable = 0;
let searchResults: Awaited<ReturnType<typeof searchCacheEntries>> = [];
let recentActivity: Awaited<ReturnType<typeof getRecentCacheActivity>> = [];
let recentActivityError = "";

if (session?.isAdmin) {
  try {
    if (query) {
      searchResults = await searchCacheEntries(query, 20);
    } else {
      const stats = await getCacheStats();
      total = stats.total;
      manualOverride = stats.manualOverride;
      deletable = stats.deletable;
    }

  } catch (err) {
    const reason = err instanceof Error ? err.message : String(err);
    console.error(`[Cache] SSR error: ${reason} → Check DB connection and cache-admin service availability`);
  }

  try {
    recentActivity = await getRecentCacheActivity(8);
  } catch (err) {
    const reason = err instanceof Error ? err.message : String(err);
    recentActivityError = reason;
    console.error(`[Cache] Recent activity SSR error: ${reason} → Check response_cache and response_edits availability`);
  }
}
---

<AdminLayout title="Cache" active="cache">
  <details class="activity-card" open>
    <summary class="activity-summary">
      <span>
        <span class="activity-kicker">Recent Cache Activity</span>
        <span class="activity-title">Latest additions and edits</span>
      </span>
      <span class="activity-meta">{recentActivity.length.toLocaleString()} items</span>
    </summary>

    {recentActivityError ? (
      <div class="activity-empty">
        <p class="activity-empty-title">Failed to load activity</p>
        <p class="activity-empty-text">{recentActivityError}</p>
      </div>
    ) : recentActivity.length > 0 ? (
      <div class="activity-table-wrap">
        <p class="activity-note">Prompt version reflects the cache row at display time, so older edits may be shown against a newer active version.</p>
        <table class="activity-table">
          <thead>
            <tr>
              <th class="col-no" scope="col">No.</th>
              <th class="col-time" scope="col">Date &amp; time</th>
              <th class="col-query" scope="col">Query</th>
              <th class="col-state" scope="col">State</th>
              <th class="col-prompt" scope="col">Prompt version</th>
              <th class="col-role" scope="col">Output Bucket</th>
            </tr>
          </thead>
          <tbody>
            {recentActivity.map((entry, index) => (
              <tr class={entry.activity === "edited" ? "row-edited" : "row-added"}>
                <td class="col-no mono">{index + 1}</td>
                <td class="col-time mono">
                  {entry.createdAt
                    ? new Intl.DateTimeFormat("ja-JP", {
                        timeZone: "Asia/Jakarta",
                        year: "numeric",
                        month: "2-digit",
                        day: "2-digit",
                        hour: "2-digit",
                        minute: "2-digit",
                        second: "2-digit",
                      }).format(entry.createdAt)
                    : "—"}
                </td>
                <td class="col-query">
                  <span class="query-cell" title={entry.query}>{entry.query}</span>
                </td>
                <td class="col-state">
                  <span
                    class={`state-pill ${entry.activity === "edited" ? "state-edited" : "state-added"}`}
                    title={entry.activity === "edited" ? "Cache edit event" : "Cache addition event"}
                  >
                    {entry.activity === "edited" ? "Edited" : "Added"}
                  </span>
                </td>
                <td class="col-prompt mono">
                  <span class="prompt-pill" title="Current cache row prompt version">{entry.promptVersion}</span>
                </td>
                <td class="col-role">
                  <span class="role-pill">{getOutputBucketLabel(entry.roleKey)}</span>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    ) : (
      <div class="activity-empty">
        <p class="activity-empty-title">No recent activity yet</p>
        <p class="activity-empty-text">New cache additions and edits will appear here as they happen.</p>
      </div>
    )}
  </details>

  {!query && (
    <div class="stats-row">
      <div class="stat-card">
        <span class="stat-label">Total Entries</span>
        <span class="stat-value">{total.toLocaleString()}</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Manual Override</span>
        <span class="stat-value">{manualOverride.toLocaleString()}</span>
      </div>
      <div class="stat-card">
        <span class="stat-label">Deletable</span>
        <span class="stat-value">{deletable.toLocaleString()}</span>
      </div>
    </div>
  )}

  <div class="search-card">
    <h2 class="section-title">{query ? "Search Results" : "Search & Refresh Cache"}</h2>
    <form method="GET" action="/admin/cache" class="search-row">
      <input
        type="text"
        name="query"
        class="search-input"
        placeholder="Search by normalized query..."
        value={query}
      />
      <button type="submit" class="btn-primary">Search</button>
      {query && (
        <a href="/admin/cache" class="btn-secondary">Clear</a>
      )}
    </form>
  </div>

  {query && searchResults.length > 0 && (
    <CacheDeletePanel
      client:load
      entries={searchResults.map((entry) => ({
        ...entry,
        outputBucketLabel: getOutputBucketLabel(entry.roleKey),
      }))}
      csrfToken={csrfToken}
    />
  )}

  {query && searchResults.length === 0 && (
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Select</th>
            <th>ID</th>
            <th>Query</th>
            <th>Prompt Version</th>
            <th>Output Bucket</th>
            <th>Protection</th>
            <th>Updated</th>
            <th>Edit</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td colspan="8" class="empty-cell">No cache entries found for "{query}".</td>
          </tr>
        </tbody>
      </table>
    </div>
  )}

  {!query && (
    <div class="info-card">
      <h2 class="section-title">Refresh Rules</h2>
      <ul class="rule-list">
        <li>Refreshing a cache entry deletes the existing auto-generated response.</li>
        <li><strong>Delete-protected</strong> entries are never deleted automatically.</li>
        <li>After deletion, the next lookup for that query will regenerate the response.</li>
        <li>Use the API or MCP dry-run tool to preview what will be deleted first.</li>
      </ul>
    </div>
  )}

</AdminLayout>

<style>
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-card {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 600;
    color: var(--color-graphite-900);
    letter-spacing: -0.015em;
  }

  .search-card,
  .info-card {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-panel);
    padding: 20px;
    margin-bottom: 20px;
  }

  .section-title {
    margin: 0 0 16px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .search-row {
    display: flex;
    gap: 8px;
  }

  .search-input {
    flex: 1;
    height: 40px;
    padding: 0 12px;
    background: var(--color-porcelain-50);
    border: 1px solid var(--color-graphite-300);
    border-radius: var(--radius-input);
    color: var(--color-graphite-900);
    font-size: 14px;
    font-family: var(--font-grkd-sans);
  }

  .search-input:focus {
    border-color: var(--color-royal-blue-600);
    outline: 3px solid var(--color-royal-blue-100);
    outline-offset: 0;
  }

  .btn-primary {
    background: var(--color-royal-blue-600);
    color: var(--color-porcelain-50);
    border: 1px solid var(--color-royal-blue-700);
    border-radius: var(--radius-button);
    padding: 0 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.1s;
  }

  .btn-primary:hover {
    background: var(--color-royal-blue-700);
  }

  .btn-secondary {
    background: var(--color-porcelain-100);
    color: var(--color-graphite-800);
    border: 1px solid var(--color-graphite-300);
    border-radius: var(--radius-button);
    padding: 0 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.1s;
  }

  .btn-secondary:hover {
    background: var(--color-porcelain-150);
  }

  .rule-list {
    margin: 0;
    padding: 0 0 0 20px;
    font-size: 14px;
    color: var(--color-graphite-650);
    line-height: 1.6;
  }

  .rule-list li {
    margin-bottom: 4px;
  }

  .table-container {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    overflow: hidden;
    margin-bottom: 20px;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    background: var(--color-porcelain-150);
    text-align: left;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table td {
    padding: 10px 12px;
    font-size: 13px;
    color: var(--color-graphite-650);
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--color-porcelain-150);
  }

  .mono {
    font-family: var(--font-grkd-mono);
    font-size: 12px;
  }

  .badge-manual {
    display: inline-block;
    background: var(--color-royal-blue-100);
    color: var(--color-royal-blue-700);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-auto {
    display: inline-block;
    background: var(--color-porcelain-150);
    color: var(--color-graphite-650);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .empty-cell {
    text-align: center;
    color: var(--color-graphite-500);
    padding: 32px;
  }

  .delete-panel {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 20px;
    margin-bottom: 20px;
  }

  .delete-toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
    gap: 12px;
  }

  .delete-info {
    font-size: 13px;
    color: var(--color-graphite-650);
  }

  .btn-select-deletable {
    background: var(--color-porcelain-150);
    color: var(--color-graphite-700);
    border: 1px solid var(--color-graphite-300);
    border-radius: var(--radius-button);
    padding: 6px 14px;
    font-size: 13px;
    font-weight: 500;
    cursor: pointer;
    transition: background 0.1s;
  }

  .btn-select-deletable:hover {
    background: var(--color-porcelain-220);
  }

  .btn-select-deletable:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .delete-actions {
    margin-bottom: 16px;
    display: flex;
    gap: 8px;
  }

  .btn-delete {
    background: var(--color-danger-600);
    color: var(--color-porcelain-50);
    border: none;
    border-radius: var(--radius-button);
    padding: 8px 16px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.1s;
  }

  .btn-delete:hover:not(:disabled) {
    background: var(--color-danger-700);
  }

  .btn-delete:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .delete-error {
    padding: 10px 14px;
    background: var(--color-danger-100);
    color: var(--color-danger-600);
    border: 1px solid var(--color-danger-600);
    border-radius: var(--radius-input);
    font-size: 13px;
    margin-bottom: 16px;
  }

  .cache-table .col-select {
    width: 40px;
    text-align: center;
  }

  .cache-entry.protected {
    opacity: 0.6;
  }

  .cache-entry.selected {
    background: var(--color-royal-blue-100);
  }

  .query-cell {
    max-width: 300px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .activity-card {
    margin-bottom: 20px;
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-panel);
    background: linear-gradient(180deg, var(--color-porcelain-100), var(--color-porcelain-50));
    overflow: hidden;
  }

  .activity-summary {
    list-style: none;
    display: flex;
    justify-content: space-between;
    gap: 16px;
    align-items: center;
    padding: 18px 20px;
    cursor: pointer;
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .activity-summary::-webkit-details-marker {
    display: none;
  }

  .activity-summary::after {
    content: "▾";
    margin-left: auto;
    font-size: 14px;
    color: var(--color-graphite-400);
    transition: transform 0.15s ease;
  }

  details[open] .activity-summary::after {
    transform: rotate(180deg);
  }

  .activity-kicker {
    display: block;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-royal-blue-600);
  }

  .activity-title {
    display: block;
    margin-top: 4px;
    font-size: 18px;
    font-weight: 600;
    color: var(--color-graphite-900);
  }

  .activity-meta {
    flex: none;
    border-radius: 999px;
    padding: 6px 12px;
    background: var(--color-royal-blue-100);
    color: var(--color-royal-blue-700);
    font-size: 12px;
    font-weight: 600;
  }

  .activity-table-wrap {
    overflow-x: auto;
  }

  .activity-note {
    margin: 0;
    padding: 14px 20px 0;
    font-size: 12px;
    color: var(--color-graphite-500);
  }

  .activity-table {
    width: 100%;
    min-width: 920px;
    border-collapse: collapse;
  }

  .activity-table th {
    padding: 12px 16px;
    background: var(--color-porcelain-150);
    border-bottom: 1px solid var(--color-graphite-180);
    color: var(--color-graphite-500);
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    text-align: center;
  }

  .activity-table td {
    padding: 14px 16px;
    border-bottom: 1px solid var(--color-graphite-180);
    color: var(--color-graphite-800);
    font-size: 14px;
    vertical-align: middle;
    text-align: center;
  }

  .activity-table tbody tr:hover {
    background: var(--color-porcelain-150);
  }

  .activity-table tbody tr:last-child td {
    border-bottom: none;
  }

  .row-edited {
    box-shadow: inset 3px 0 0 var(--color-royal-blue-600);
  }

  .row-added {
    box-shadow: inset 3px 0 0 var(--color-success-600);
  }

  .state-pill,
  .prompt-pill,
  .role-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    white-space: nowrap;
  }

  .state-pill {
    padding: 4px 10px;
    font-size: 12px;
    font-weight: 600;
  }

  .state-added {
    background: var(--color-success-100);
    color: var(--color-success-600);
  }

  .state-edited {
    background: var(--color-royal-blue-100);
    color: var(--color-royal-blue-700);
  }

  .prompt-pill {
    padding: 4px 10px;
    background: var(--color-porcelain-150);
    border: 1px solid var(--color-graphite-180);
    color: var(--color-graphite-650);
  }

  .role-pill {
    padding: 4px 10px;
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    color: var(--color-graphite-800);
    font-weight: 500;
  }

  .activity-empty {
    padding: 28px 20px 30px;
    text-align: center;
  }

  .activity-empty-title {
    margin: 0;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .activity-empty-text {
    margin: 8px 0 0;
    font-size: 14px;
    color: var(--color-graphite-500);
  }

  @media (max-width: 900px) {
    .activity-summary {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>
