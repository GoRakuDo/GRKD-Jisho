---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { getCacheStats } from "@grkd-jisho/db";

const session = getSession(Astro);

let total = 0;
let manualOverride = 0;
let deletable = 0;

if (session?.isAdmin) {
  try {
    const stats = await getCacheStats();
    total = stats.total;
    manualOverride = stats.manualOverride;
    deletable = stats.deletable;
  } catch (err) {
    console.error("Cache SSR error:", err);
  }
}
---

<AdminLayout title="Cache" active="cache">
  <div class="stats-row">
    <div class="stat-card">
      <span class="stat-label">Total Entries</span>
      <span class="stat-value">{total.toLocaleString()}</span>
    </div>
    <div class="stat-card">
      <span class="stat-label">Manual Override</span>
      <span class="stat-value">{manualOverride.toLocaleString()}</span>
    </div>
    <div class="stat-card">
      <span class="stat-label">Deletable</span>
      <span class="stat-value">{deletable.toLocaleString()}</span>
    </div>
  </div>

  <div class="search-card">
    <h2 class="section-title">Search &amp; Refresh Cache</h2>
    <form method="GET" action="/admin/cache" class="search-row">
      <input
        type="text"
        name="query"
        class="search-input"
        placeholder="Search by normalized query..."
      />
      <button type="submit" class="btn-primary">Search</button>
    </form>
  </div>

  <div class="info-card">
    <h2 class="section-title">Refresh Rules</h2>
    <ul class="rule-list">
      <li>Refreshing a cache entry deletes the existing auto-generated response.</li>
      <li><strong>Manual override</strong> entries are never deleted automatically.</li>
      <li>After deletion, the next lookup for that query will regenerate the response.</li>
      <li>Use the API or MCP dry-run tool to preview what will be deleted first.</li>
    </ul>
  </div>
</AdminLayout>

<style>
  .stats-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 24px;
  }

  .stat-card {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .stat-label {
    font-size: 13px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    letter-spacing: 0.01em;
  }

  .stat-value {
    font-size: 28px;
    font-weight: 600;
    color: var(--color-graphite-900);
    letter-spacing: -0.015em;
  }

  .search-card,
  .info-card {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-panel);
    padding: 20px;
    margin-bottom: 20px;
  }

  .section-title {
    margin: 0 0 16px;
    font-size: 16px;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .search-row {
    display: flex;
    gap: 8px;
  }

  .search-input {
    flex: 1;
    height: 40px;
    padding: 0 12px;
    background: var(--color-porcelain-50);
    border: 1px solid var(--color-graphite-300);
    border-radius: var(--radius-input);
    color: var(--color-graphite-900);
    font-size: 14px;
    font-family: var(--font-grkd-sans);
  }

  .search-input:focus {
    border-color: var(--color-royal-blue-600);
    outline: 3px solid var(--color-royal-blue-100);
    outline-offset: 0;
  }

  .btn-primary {
    background: var(--color-royal-blue-600);
    color: var(--color-porcelain-50);
    border: 1px solid var(--color-royal-blue-700);
    border-radius: var(--radius-button);
    padding: 0 16px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.1s;
  }

  .btn-primary:hover {
    background: var(--color-royal-blue-700);
  }

  .rule-list {
    margin: 0;
    padding: 0 0 0 20px;
    font-size: 14px;
    color: var(--color-graphite-650);
    line-height: 1.6;
  }

  .rule-list li {
    margin-bottom: 4px;
  }
</style>
