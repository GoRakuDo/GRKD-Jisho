---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import {
  getDictionaryList,
  getDictionaryEntryCount,
} from "@grkd-jisho/db";

const session = getSession(Astro);

interface DictWithCount {
  id: string;
  name: string;
  slug: string;
  priority: number;
  enabled: boolean;
  entryCount: number;
}

let dictionaries: DictWithCount[] = [];

if (session?.isAdmin) {
  try {
    const dicts = await getDictionaryList();
    dictionaries = await Promise.all(
      dicts.map(async (d) => {
        const entryCount = await getDictionaryEntryCount(d.id);
        return {
          id: String(d.id),
          name: d.name,
          slug: d.slug,
          priority: d.priority,
          enabled: d.enabled,
          entryCount,
        };
      }),
    );
  } catch (err) {
    console.error("Dictionaries SSR error:", err);
  }
}
---

<AdminLayout title="Dictionaries" active="dictionaries">
  {dictionaries.length === 0 && (
    <div class="empty-state">
      <p>No dictionaries found.</p>
    </div>
  )}

  {dictionaries.length > 0 && (
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Priority</th>
            <th>Name</th>
            <th>Slug</th>
            <th>Entries</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {dictionaries.map((d) => (
            <tr>
              <td class="priority-cell">{d.priority}</td>
              <td class="name-cell">{d.name}</td>
              <td class="mono">{d.slug}</td>
              <td class="mono">{d.entryCount.toLocaleString()}</td>
              <td>
                {d.enabled ? (
                  <span class="badge-enabled">enabled</span>
                ) : (
                  <span class="badge-disabled">disabled</span>
                )}
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<style>
  .table-container {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    background: var(--color-porcelain-150);
    text-align: left;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table td {
    padding: 10px 12px;
    font-size: 13px;
    color: var(--color-graphite-650);
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--color-porcelain-150);
  }

  .mono {
    font-family: var(--font-grkd-mono);
    font-size: 12px;
  }

  .priority-cell {
    text-align: center;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .name-cell {
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .badge-enabled {
    display: inline-block;
    background: var(--color-success-100);
    color: var(--color-success-600);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .badge-disabled {
    display: inline-block;
    background: var(--color-porcelain-150);
    color: var(--color-graphite-650);
    padding: 2px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
  }

  .empty-state {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 40px;
    text-align: center;
    color: var(--color-graphite-500);
    font-size: 14px;
  }
</style>
