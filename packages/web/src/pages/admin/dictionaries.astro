---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import {
  getDictionaryList,
  db,
  schema,
} from "@grkd-jisho/db";
import { count } from "drizzle-orm";
import { generateCsrfToken } from "../../lib/csrf";

const session = getSession(Astro);
const csrfToken = session ? generateCsrfToken(session.discordUserId) : "";

interface DictWithCount {
  id: string;
  name: string;
  slug: string;
  priority: number;
  enabled: boolean;
  entryCount: number;
}

let dictionaries: DictWithCount[] = [];

if (session?.isAdmin) {
  try {
    const dicts = await getDictionaryList();
    const entryCounts = await db
      .select({
        dictId: schema.dictionaryEntries.dictionaryId,
        count: count(schema.dictionaryEntries.id),
      })
      .from(schema.dictionaryEntries)
      .groupBy(schema.dictionaryEntries.dictionaryId);

    const freqCounts = await db
      .select({
        dictId: schema.termFrequencies.dictionaryId,
        count: count(schema.termFrequencies.id),
      })
      .from(schema.termFrequencies)
      .groupBy(schema.termFrequencies.dictionaryId);

    const entryCountMap = new Map(entryCounts.map((r) => [String(r.dictId), Number(r.count)]));
    const freqCountMap = new Map(freqCounts.map((r) => [String(r.dictId), Number(r.count)]));

    dictionaries = dicts.map((d) => ({
      id: String(d.id),
      name: d.name,
      slug: d.slug,
      priority: d.priority,
      enabled: d.enabled,
      entryCount: (entryCountMap.get(String(d.id)) ?? 0) + (freqCountMap.get(String(d.id)) ?? 0),
    }));
  } catch (err) {
    const reason = err instanceof Error ? err.message : String(err);
    console.error(`[Dictionaries] SSR error: ${reason} → Check DB connection and session validity`);
  }
}
---

<script>
document.addEventListener('DOMContentLoaded', () => {
  const SSR_CSRF_TOKEN = document.querySelector<HTMLMetaElement>('meta[name="csrf-token"]')?.content ?? '';

  async function updateDictionary(dictId: string, updates: { enabled?: boolean; priority?: number }) {
    const row = document.querySelector(`tr[data-dict-id="${dictId}"]`) as HTMLTableRowElement | null;
    if (!row) return;

    try {
      row.style.opacity = '0.5';

      const res = await fetch('/api/admin/dictionaries', {
        method: 'PUT',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': SSR_CSRF_TOKEN,
        },
        body: JSON.stringify({ id: Number(dictId), ...updates }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || `Update failed (${res.status})`);
      }

      // Optimistic UI update
      if (updates.enabled !== undefined) {
        const badge = row.querySelector<HTMLSpanElement>('.status-badge');
        if (badge) {
          const newEnabled = updates.enabled;
          badge.className = `status-badge ${newEnabled ? 'badge-enabled' : 'badge-disabled'}`;
          badge.textContent = newEnabled ? 'enabled' : 'disabled';
          badge.setAttribute('data-enabled', String(newEnabled));
        }
      }

      if (updates.priority !== undefined) {
        const input = row.querySelector<HTMLInputElement>('.priority-input');
        if (input) {
          input.value = String(updates.priority);
        }
      }
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Update failed';
      console.error(`[DictionaryUpdate] ${msg} → Check CSRF token and session validity`);
      alert(msg);
    } finally {
      row.style.opacity = '1';
    }
  }

  // Status toggle
  document.querySelectorAll('.status-badge').forEach((badge) => {
    badge.addEventListener('click', async () => {
      const row = badge.closest('tr') as HTMLTableRowElement;
      const dictId = row?.getAttribute('data-dict-id');
      const currentEnabled = badge.getAttribute('data-enabled') === 'true';
      if (!dictId) return;
      await updateDictionary(dictId, { enabled: !currentEnabled });
    });
  });

  // Priority input
  document.querySelectorAll('.priority-input').forEach((input) => {
    input.addEventListener('change', async () => {
      const row = input.closest('tr') as HTMLTableRowElement | null;
      const dictId = row?.getAttribute('data-dict-id');
      const priority = parseInt((input as HTMLInputElement).value, 10);
      if (!dictId || Number.isNaN(priority)) return;
      await updateDictionary(dictId, { priority });
    });
  });
});
</script>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const SSR_CSRF_TOKEN = document.querySelector<HTMLMetaElement>('meta[name="csrf-token"]')?.content ?? '';
  const fileInput = document.getElementById('freq-file-input') as HTMLInputElement;
  const uploadArea = document.getElementById('freq-upload-area')!;
  const previewDiv = document.getElementById('freq-preview')!;
  const successDiv = document.getElementById('freq-success')!;
  const errorDiv = document.getElementById('freq-error')!;
  const previewTitle = document.getElementById('freq-preview-title')!;
  const previewMeta = document.getElementById('freq-preview-meta')!;
  const previewTbody = document.getElementById('freq-preview-tbody')!;
  const importBtn = document.getElementById('freq-import-btn') as HTMLButtonElement;
  const cancelBtn = document.getElementById('freq-cancel-btn')!;
  const enableBtn = document.getElementById('freq-enable-btn')!;

  let selectedFile: File | null = null;
  let importedDictId: string | null = null;

  function getFrequencyMode(): string {
    return (document.getElementById('freq-mode-select') as HTMLSelectElement)?.value ?? 'rank-based';
  }

  function showError(msg: string) {
    errorDiv.style.display = 'flex';
    document.getElementById('freq-error-text')!.textContent = msg;
    successDiv.style.display = 'none';
  }

  function hideError() {
    errorDiv.style.display = 'none';
  }

  function showSuccess(msg: string) {
    successDiv.style.display = 'flex';
    document.getElementById('freq-success-text')!.textContent = msg;
    errorDiv.style.display = 'none';
  }

  function resetToUpload() {
    previewDiv.style.display = 'none';
    uploadArea.style.display = 'flex';
    selectedFile = null;
    if (fileInput) fileInput.value = '';
    hideError();
  }

  fileInput?.addEventListener('change', async () => {
    const file = fileInput.files?.[0];
    if (!file) return;
    selectedFile = file;
    hideError();

    const formData = new FormData();
    formData.append('file', file);
    formData.append('frequencyMode', getFrequencyMode());

    try {
      uploadArea.style.display = 'none';
      previewDiv.style.display = 'block';

      const res = await fetch('/api/admin/frequencies/preview', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'x-csrf-token': SSR_CSRF_TOKEN },
        body: formData,
      });

      const data = await res.json();
      if (!res.ok) {
        throw new Error(data.error || `Preview failed (${res.status})`);
      }

      previewTitle.textContent = `${data.totalEntries.toLocaleString()} frequency entries`;
      previewMeta.textContent = `Mode: ${data.frequencyMode} | File: ${data.fileName} (${(data.fileSize / 1024).toFixed(1)} KB)`;

      previewTbody.innerHTML = '';
      for (const entry of data.sampleEntries) {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td class="mono">${escapeHtml(entry.expression)}</td><td class="mono">${escapeHtml(entry.reading ?? '-')}</td><td class="mono">${escapeHtml(String(entry.frequency))}</td><td class="mono">${escapeHtml(entry.display)}</td>`;
        previewTbody.appendChild(tr);
      }

      if (data.sampleEntries.length < data.totalEntries) {
        const tr = document.createElement('tr');
        tr.innerHTML = `<td colspan="4" style="text-align: center; color: var(--color-graphite-500); font-style: italic;">... and ${(data.totalEntries - data.sampleEntries.length).toLocaleString()} more entries</td>`;
        previewTbody.appendChild(tr);
      }
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Preview failed';
      showError(msg);
      resetToUpload();
    }
  });

  cancelBtn?.addEventListener('click', resetToUpload);

  enableBtn?.addEventListener('click', async () => {
    if (!importedDictId) return;
    enableBtn.disabled = true;
    enableBtn.textContent = 'Enabling...';
    try {
      const res = await fetch('/api/admin/dictionaries', {
        method: 'PUT',
        credentials: 'same-origin',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': SSR_CSRF_TOKEN },
        body: JSON.stringify({ id: Number(importedDictId), enabled: true }),
      });
      if (res.ok) {
        enableBtn.textContent = 'Enabled!';
        enableBtn.style.background = 'var(--color-success-600)';
        setTimeout(() => { enableBtn.style.display = 'none'; }, 2000);
      } else {
        throw new Error('Failed to enable');
      }
    } catch {
      enableBtn.disabled = false;
      enableBtn.textContent = 'Enable Now';
      showError('Failed to enable dictionary. Try from the dictionary table above.');
    }
  });

  importBtn?.addEventListener('click', async () => {
    if (!selectedFile) return;

    const formData = new FormData();
    formData.append('file', selectedFile);
    formData.append('dictionaryName', selectedFile.name.replace(/\.zip$/i, '').replace(/[[\]]/g, '').trim());
    formData.append('frequencyMode', getFrequencyMode());

    importBtn.disabled = true;
    importBtn.textContent = 'Importing...';
    hideError();

    try {
      const res = await fetch('/api/admin/frequencies/import', {
        method: 'POST',
        credentials: 'same-origin',
        headers: { 'x-csrf-token': SSR_CSRF_TOKEN },
        body: formData,
      });

      const data = await res.json();
      if (!res.ok) {
        throw new Error(data.error || `Import failed (${res.status})`);
      }

      const r = data.result;
      importedDictId = r.dictionaryId;
      showSuccess(`Imported ${r.imported.toLocaleString()} frequency entries into "${r.dictionaryName}". Frequency dictionaries must be enabled to affect reading ranker.`);
      enableBtn.style.display = 'inline-flex';
      previewDiv.style.display = 'none';
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Import failed';
      showError(msg);
    } finally {
      importBtn.disabled = false;
      importBtn.textContent = 'Import Frequency Data';
    }
  });

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }
});
</script>

<AdminLayout title="Dictionaries" active="dictionaries" csrfToken={csrfToken}>
  <div class="page-header">
    <div>
      <h1 class="page-title">Dictionaries</h1>
      <p class="page-description">Manage dictionary priority and import Yomitan-compatible dictionary ZIP files.</p>
    </div>
    <a href="/admin/dictionaries/import" class="import-button">Import Dictionary</a>
  </div>

  {dictionaries.length === 0 && (
    <div class="empty-state">
      <p class="empty-title">No dictionaries available</p>
      <p class="empty-description">Your dictionary library is currently empty. Import your first Yomitan-compatible ZIP file to begin providing meanings to your learners.</p>
      <a href="/admin/dictionaries/import" class="empty-cta">Get Started: Import Dictionary</a>
    </div>
  )}

  {dictionaries.length > 0 && (
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Priority</th>
            <th>Name</th>
            <th>Slug</th>
            <th>Entries</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {dictionaries.map((d) => (
            <tr data-dict-id={d.id}>
              <td class="priority-cell">
                <input
                  type="number"
                  class="priority-input"
                  value={d.priority}
                  min={0}
                  max={9999}
                  aria-label={`Priority for ${d.name}`}
                />
              </td>
              <td class="name-cell">{d.name}</td>
              <td class="mono">{d.slug}</td>
              <td class="mono">{d.entryCount.toLocaleString()}</td>
              <td>
                <span
                  class={`status-badge ${d.enabled ? 'badge-enabled' : 'badge-disabled'}`}
                  data-enabled={d.enabled}
                  style="cursor: pointer;"
                  title="Click to toggle"
                >
                  {d.enabled ? 'enabled' : 'disabled'}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  {session?.isAdmin && (
  <div class="freq-section">
    <div class="freq-header">
      <div>
        <h2 class="freq-title">Frequency Data</h2>
        <p class="freq-description">Import Yomitan frequency ZIP files to rank dictionary readings by usage frequency.</p>
      </div>
    </div>

    <div id="freq-upload-area" class="freq-upload-area">
      <svg class="freq-upload-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="17 8 12 3 7 8"/>
        <line x1="12" y1="3" x2="12" y2="15"/>
      </svg>
      <p class="freq-upload-text">Drop a frequency .zip file here, or <label for="freq-file-input" class="freq-upload-link">browse</label></p>
      <p class="freq-upload-hint">term_meta_bank_*.json files inside a Yomitan-compatible ZIP</p>
      <div class="freq-mode-row">
        <label for="freq-mode-select" class="freq-mode-label">Frequency Mode:</label>
        <select id="freq-mode-select" class="freq-mode-select">
          <option value="rank-based" selected>Rank-based (lower = more common)</option>
          <option value="occurrence-based">Occurrence-based (higher = more common)</option>
        </select>
      </div>
      <input type="file" id="freq-file-input" accept=".zip" style="display: none;" />
    </div>

    <div id="freq-preview" class="freq-preview" style="display: none;">
      <div class="freq-preview-header">
        <div>
          <p class="freq-preview-title" id="freq-preview-title"></p>
          <p class="freq-preview-meta" id="freq-preview-meta"></p>
        </div>
        <div class="freq-preview-actions">
          <button id="freq-cancel-btn" class="freq-btn-secondary">Cancel</button>
          <button id="freq-import-btn" class="freq-btn-primary">Import Frequency Data</button>
        </div>
      </div>
      <div class="freq-preview-table-wrap">
        <table class="freq-preview-table">
          <thead>
            <tr>
              <th>Expression</th>
              <th>Reading</th>
              <th>Frequency</th>
              <th>Display</th>
            </tr>
          </thead>
          <tbody id="freq-preview-tbody"></tbody>
        </table>
      </div>
    </div>

    <div id="freq-success" class="freq-success" style="display: none;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
        <polyline points="22 4 12 14.01 9 11.01"/>
      </svg>
      <span id="freq-success-text"></span>
      <button id="freq-enable-btn" class="freq-btn-primary" style="display: none;">Enable Now</button>
    </div>

    <div id="freq-error" class="freq-error" style="display: none;">
      <span id="freq-error-text"></span>
    </div>
  </div>
  )}
</AdminLayout>

<style>
