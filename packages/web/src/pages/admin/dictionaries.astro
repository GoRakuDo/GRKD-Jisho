---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import {
  getDictionaryList,
  db,
  schema,
} from "@grkd-jisho/db";
import { count } from "drizzle-orm";
import { generateCsrfToken } from "../../lib/csrf";

const session = getSession(Astro);
const csrfToken = session ? generateCsrfToken(session.discordUserId) : "";

interface DictWithCount {
  id: string;
  name: string;
  slug: string;
  priority: number;
  enabled: boolean;
  entryCount: number;
}

let dictionaries: DictWithCount[] = [];

if (session?.isAdmin) {
  try {
    const dicts = await getDictionaryList();
    const entryCounts = await db
      .select({
        dictId: schema.dictionaryEntries.dictionaryId,
        count: count(schema.dictionaryEntries.id),
      })
      .from(schema.dictionaryEntries)
      .groupBy(schema.dictionaryEntries.dictionaryId);

    const countMap = new Map(entryCounts.map((r) => [String(r.dictId), Number(r.count)]));

    dictionaries = dicts.map((d) => ({
      id: String(d.id),
      name: d.name,
      slug: d.slug,
      priority: d.priority,
      enabled: d.enabled,
      entryCount: countMap.get(String(d.id)) ?? 0,
    }));
  } catch (err) {
    const reason = err instanceof Error ? err.message : String(err);
    console.error(`[Dictionaries] SSR error: ${reason} → Check DB connection and session validity`);
  }
}
---

<meta name="csrf-token" content={csrfToken} />

<script>
document.addEventListener('DOMContentLoaded', () => {
  const SSR_CSRF_TOKEN = document.querySelector<HTMLMetaElement>('meta[name="csrf-token"]')?.content ?? '';

  async function updateDictionary(dictId: string, updates: { enabled?: boolean; priority?: number }) {
    const row = document.querySelector(`tr[data-dict-id="${dictId}"]`) as HTMLTableRowElement | null;
    if (!row) return;

    try {
      row.style.opacity = '0.5';

      const res = await fetch('/api/admin/dictionaries', {
        method: 'PUT',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          'x-csrf-token': SSR_CSRF_TOKEN,
        },
        body: JSON.stringify({ id: Number(dictId), ...updates }),
      });

      if (!res.ok) {
        const data = await res.json().catch(() => ({}));
        throw new Error(data.error || `Update failed (${res.status})`);
      }

      // Optimistic UI update
      if (updates.enabled !== undefined) {
        const badge = row.querySelector<HTMLSpanElement>('.status-badge');
        if (badge) {
          const newEnabled = updates.enabled;
          badge.className = `status-badge ${newEnabled ? 'badge-enabled' : 'badge-disabled'}`;
          badge.textContent = newEnabled ? 'enabled' : 'disabled';
          badge.setAttribute('data-enabled', String(newEnabled));
        }
      }

      if (updates.priority !== undefined) {
        const input = row.querySelector<HTMLInputElement>('.priority-input');
        if (input) {
          input.value = String(updates.priority);
        }
      }
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Update failed';
      console.error(`[DictionaryUpdate] ${msg} → Check CSRF token and session validity`);
      alert(msg);
    } finally {
      row.style.opacity = '1';
    }
  }

  // Status toggle
  document.querySelectorAll('.status-badge').forEach((badge) => {
    badge.addEventListener('click', async () => {
      const row = badge.closest('tr') as HTMLTableRowElement;
      const dictId = row?.getAttribute('data-dict-id');
      const currentEnabled = badge.getAttribute('data-enabled') === 'true';
      if (!dictId) return;
      await updateDictionary(dictId, { enabled: !currentEnabled });
    });
  });

  // Priority input
  document.querySelectorAll('.priority-input').forEach((input) => {
    input.addEventListener('change', async () => {
      const row = input.closest('tr') as HTMLTableRowElement | null;
      const dictId = row?.getAttribute('data-dict-id');
      const priority = parseInt((input as HTMLInputElement).value, 10);
      if (!dictId || Number.isNaN(priority)) return;
      await updateDictionary(dictId, { priority });
    });
  });
});
</script>

<AdminLayout title="Dictionaries" active="dictionaries">
  <div class="page-header">
    <div>
      <h1 class="page-title">Dictionaries</h1>
      <p class="page-description">Manage dictionary priority and import Yomitan-compatible dictionary ZIP files.</p>
    </div>
    <a href="/admin/dictionaries/import" class="import-button">Import Dictionary</a>
  </div>

  {dictionaries.length === 0 && (
    <div class="empty-state">
      <p class="empty-title">No dictionaries available</p>
      <p class="empty-description">Your dictionary library is currently empty. Import your first Yomitan-compatible ZIP file to begin providing meanings to your learners.</p>
      <a href="/admin/dictionaries/import" class="empty-cta">Get Started: Import Dictionary</a>
    </div>
  )}

  {dictionaries.length > 0 && (
    <div class="table-container">
      <table class="data-table">
        <thead>
          <tr>
            <th>Priority</th>
            <th>Name</th>
            <th>Slug</th>
            <th>Entries</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          {dictionaries.map((d) => (
            <tr data-dict-id={d.id}>
              <td class="priority-cell">
                <input
                  type="number"
                  class="priority-input"
                  value={d.priority}
                  min={0}
                  max={9999}
                  aria-label={`Priority for ${d.name}`}
                />
              </td>
              <td class="name-cell">{d.name}</td>
              <td class="mono">{d.slug}</td>
              <td class="mono">{d.entryCount.toLocaleString()}</td>
              <td>
                <span
                  class={`status-badge ${d.enabled ? 'badge-enabled' : 'badge-disabled'}`}
                  data-enabled={d.enabled}
                  style="cursor: pointer;"
                  title="Click to toggle"
                >
                  {d.enabled ? 'enabled' : 'disabled'}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</AdminLayout>

<style>
  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 16px;
  }

  .page-title {
    font-size: 20px;
    line-height: 1.3;
    font-weight: 600;
    color: var(--color-graphite-800);
    margin: 0;
  }

  .page-description {
    margin: 4px 0 0;
    font-size: 13px;
    color: var(--color-graphite-500);
  }

  .import-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    white-space: nowrap;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: var(--radius-button);
    background: var(--color-royal-blue-600);
    color: var(--color-porcelain-50);
    border: 1px solid var(--color-royal-blue-700);
    transition: background-color 0.18s ease;
  }

  .import-button:hover {
    background: var(--color-royal-blue-700);
  }

  .import-button:focus-visible {
    outline: none;
    box-shadow: 0 0 0 3px var(--color-royal-blue-100);
  }

  .table-container {
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    overflow: hidden;
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
  }

  .data-table th {
    background: var(--color-porcelain-150);
    text-align: left;
    padding: 10px 12px;
    font-size: 12px;
    font-weight: 500;
    color: var(--color-graphite-500);
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table td {
    padding: 10px 12px;
    font-size: 13px;
    color: var(--color-graphite-650);
    border-bottom: 1px solid var(--color-graphite-180);
  }

  .data-table tr:last-child td {
    border-bottom: none;
  }

  .data-table tbody tr:hover {
    background: var(--color-porcelain-150);
  }

  .mono {
    font-family: var(--font-grkd-mono);
    font-size: 12px;
  }

  .priority-cell {
    text-align: center;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .priority-input {
    width: 70px;
    padding: 4px 8px;
    border: 1px solid var(--color-graphite-300);
    border-radius: var(--radius-input);
    background: var(--color-porcelain-50);
    color: var(--color-graphite-900);
    font-size: 13px;
    text-align: center;
    outline: none;
  }

  .priority-input:focus {
    border-color: var(--color-royal-blue-600);
    box-shadow: 0 0 0 2px var(--color-royal-blue-100);
  }

  .priority-input:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .name-cell {
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .status-badge {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 500;
    user-select: none;
  }

  .badge-enabled {
    background: var(--color-success-100);
    color: var(--color-success-600);
  }

  .badge-enabled:hover {
    background: var(--color-success-200);
  }

  .badge-disabled {
    background: var(--color-porcelain-150);
    color: var(--color-graphite-650);
  }

  .badge-disabled:hover {
    background: var(--color-porcelain-200);
  }

  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    background: var(--color-porcelain-100);
    border: 1px solid var(--color-graphite-180);
    border-radius: var(--radius-card);
    padding: 40px;
    text-align: center;
  }

  .empty-title {
    margin: 0;
    font-size: 14px;
    font-weight: 600;
    color: var(--color-graphite-800);
  }

  .empty-description {
    margin: 0;
    max-width: 520px;
    font-size: 13px;
    color: var(--color-graphite-500);
  }

  .empty-cta {
    margin-top: 6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    padding: 10px 14px;
    border-radius: var(--radius-button);
    border: 1px solid var(--color-graphite-300);
    color: var(--color-graphite-800);
    background: var(--color-porcelain-150);
    transition: background-color 0.18s ease;
  }

  .empty-cta:hover {
    background: var(--color-porcelain-220);
  }

  @media (max-width: 760px) {
    .page-header {
      flex-direction: column;
      align-items: stretch;
    }

    .import-button {
      width: 100%;
    }
  }
</style>
