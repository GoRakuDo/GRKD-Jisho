---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { generateCsrfToken } from "../../lib/csrf";
import { Button } from "../../components/admin/Button";
import { OUTPUT_BUCKET_KEYS, getOutputBucketLabel } from "@grkd-jisho/db";
import { WEBUI_CONFIG } from "../../config/webui";

const roleSettingsUi = WEBUI_CONFIG.roleSettings;

const session = getSession(Astro);
const csrfToken = session ? generateCsrfToken(session.discordUserId) : "";

if (!session?.isAdmin) {
  return Astro.redirect("/auth/login");
}
---

<AdminLayout title={roleSettingsUi.page.title} active="role-settings" csrfToken={csrfToken}>
  <div class="page-header">
    <div>
      <h1 class="page-title">{roleSettingsUi.page.title}</h1>
      <p class="page-description">{roleSettingsUi.page.description}</p>
    </div>
    <Button variant="secondary" id="add-role-btn">
      {roleSettingsUi.page.addRoleLimit}
    </Button>
  </div>

  <div class="info-card">
    <div class="section-header">
      <h2 class="section-title">{roleSettingsUi.page.defaultLimitTitle}</h2>
      <button id="edit-default-btn" class="btn-ghost">{roleSettingsUi.page.defaultLimitEdit}</button>
    </div>
    <p class="info-text">
      {roleSettingsUi.page.defaultLimitCopy} <strong id="default-limit-display">—</strong>{roleSettingsUi.page.searchesPerDaySuffix}
    </p>
    <p class="info-hint">{roleSettingsUi.page.defaultLimitHint}</p>
  </div>

  <div id="table-container" class="table-container">
    <!-- Hydrated by client script -->
  </div>

  <div class="info-card info-card-reset" style="margin-top: 20px;">
    <h2 class="section-title">{roleSettingsUi.page.resetTitle}</h2>
    <p class="info-text" style="margin-bottom: 12px;">{roleSettingsUi.page.resetCopy}</p>
    <div class="reset-row">
      <div class="field-group">
        <label class="field-label" for="reset-user-id">{roleSettingsUi.page.fieldLabels.resetUserId}</label>
        <input type="text" id="reset-user-id" class="text-input" placeholder={roleSettingsUi.page.placeholders.resetUserId} />
      </div>
      <div class="field-group">
        <label class="field-label" for="reset-guild-id">{roleSettingsUi.page.fieldLabels.resetGuildId}</label>
        <input type="text" id="reset-guild-id" class="text-input" placeholder={roleSettingsUi.page.placeholders.resetGuildId} />
      </div>
      <button id="reset-usage-btn" class="btn-primary">{roleSettingsUi.page.resetButton}</button>
    </div>
    <p id="reset-result" class="reset-result"></p>
  </div>

  <div id="role-modal" class="modal-overlay hidden">
    <div class="modal-content">
      <div class="editor-panel">
        <div class="editor-header">
          <h3 id="role-modal-title" class="editor-title">{roleSettingsUi.page.roleModalAdd}</h3>
          <button id="role-modal-close" class="btn-secondary" style="padding: 6px 14px; font-size: 13px;">{roleSettingsUi.page.roleModalClose}</button>
        </div>

        <div class="editor-grid" style="grid-template-columns: 1fr;">
          <div class="editor-col">
            <label class="editor-col-label">{roleSettingsUi.page.fieldLabels.roleId}</label>
            <input type="text" id="role-id-input" class="text-input" placeholder={roleSettingsUi.page.placeholders.roleId} />
          </div>
          <div class="editor-col">
            <label class="editor-col-label">{roleSettingsUi.page.fieldLabels.roleLabel}</label>
            <input type="text" id="role-label-input" class="text-input" placeholder={roleSettingsUi.page.placeholders.roleLabel} />
          </div>
          <div class="editor-col">
            <label class="editor-col-label">{roleSettingsUi.page.fieldLabels.dailyLimit}</label>
            <input type="number" id="role-limit-input" class="text-input" placeholder={roleSettingsUi.page.placeholders.dailyLimit} min="-1" max="99999" />
            <span class="field-hint">{roleSettingsUi.page.hints.dailyLimit}</span>
          </div>
        </div>

        <div class="editor-footer">
          <button id="role-cancel-btn" class="btn-secondary">{roleSettingsUi.page.roleModalCancel}</button>
          <button id="role-save-btn" class="btn-primary">{roleSettingsUi.page.roleModalSave}</button>
        </div>
      </div>
    </div>
  </div>
  <!-- Output Bucket Bindings -->
  <div class="section-divider"></div>
  <div class="page-header" style="margin-top: 32px;">
    <div>
      <h2 class="section-title" style="margin: 0;">{roleSettingsUi.page.bindingsTitle}</h2>
      <p class="info-text" style="margin: 4px 0 0;">{roleSettingsUi.page.bindingsCopy}</p>
      <p class="info-hint" style="margin: 4px 0 0;">{roleSettingsUi.page.bindingsHint}</p>
    </div>
    <Button variant="secondary" id="add-binding-btn">
      {roleSettingsUi.page.addBinding}
    </Button>
  </div>

  <div id="bindings-container" class="table-container">
    <!-- Hydrated by client script -->
  </div>

  <!-- Role Binding Editor Modal -->
  <div id="binding-modal" class="modal-overlay hidden">
    <div class="modal-content modal-content-small">
      <h3 class="editor-title" style="margin-bottom: 16px;">{roleSettingsUi.page.bindingModalTitle}</h3>
      <div class="field-group">
        <label class="field-label" for="binding-role-id">{roleSettingsUi.page.fieldLabels.bindingRoleId}</label>
        <input type="text" id="binding-role-id" class="text-input" placeholder={roleSettingsUi.page.placeholders.bindingRoleId} />
      </div>
      <div class="field-group">
        <label class="field-label" for="binding-output-bucket">{roleSettingsUi.page.fieldLabels.bindingBucket}</label>
        <select id="binding-output-bucket" class="text-input">
          {OUTPUT_BUCKET_KEYS.map((value) => (
            <option value={value}>{getOutputBucketLabel(value)}</option>
          ))}
        </select>
      </div>
      <div class="editor-footer">
        <button id="binding-cancel-btn" class="btn-secondary">{roleSettingsUi.page.bindingModalCancel}</button>
        <button id="binding-save-btn" class="btn-primary">{roleSettingsUi.page.bindingModalSave}</button>
      </div>
    </div>
  </div>
</AdminLayout>

<script>
import { WEBUI_CONFIG } from '../../config/webui';

const roleSettingsUi = WEBUI_CONFIG.roleSettings;
const outputBucketLabels: Record<string, string> = WEBUI_CONFIG.shared.outputBucketLabels;

// ── Types ──
type RoleLimit = {
  discordRoleId: string;
  roleLabel: string | null;
  dailyLimit: number;
  createdAt: string;
  updatedAt: string;
};

// ── State ──
let roleCache: RoleLimit[] = [];
let editingDiscordRoleId: string | null = null;
let lastFocusedRoleTrigger: HTMLElement | null = null;
let lastFocusedBindingTrigger: HTMLElement | null = null;
let currentDefaultLimit: number = 10;
const csrfToken = (document.querySelector('meta[name="csrf-token"]') as HTMLMetaElement | null)?.getAttribute("content") ?? "";

// ── Helpers ──
function getEl<T extends HTMLElement = HTMLElement>(id: string): T | null {
  return document.getElementById(id) as T | null;
}

  // ── Fetch & Render Table ──
  async function renderTable() {
    try {
      const res = await fetch("/api/admin/role-limits", {
      credentials: "same-origin",
    });

    if (!res.ok) {
      const errBody = await res.text();
      console.error("[RoleLimits] GET", res.status, res.statusText, errBody);
      const container2 = getEl("table-container");
      if (container2) container2.innerHTML = '<p style="color:var(--color-danger-600)">Failed to load (HTTP ' + res.status + '). See console.</p>';
      return;
    }

    const data = await res.json();
    roleCache = data.roleLimits || [];
    currentDefaultLimit = data.defaultLimit ?? 10;
    const defaultLimit = currentDefaultLimit;

      const defaultDisplay = getEl("default-limit-display");
      if (defaultDisplay) defaultDisplay.textContent = defaultLimit === -1 ? roleSettingsUi.page.unlimitedLabel : defaultLimit + roleSettingsUi.page.perDaySuffix;

      const container = getEl("table-container");
      if (!container) return;

      if (roleCache.length === 0) {
        container.innerHTML = `
          <table class="data-table w-full text-left border-collapse">
            <thead>
              <tr class="bg-porcelain-150 border-b border-graphite-180">
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">${roleSettingsUi.page.tableHeaders.roleName}</th>
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">${roleSettingsUi.page.tableHeaders.roleId}</th>
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">${roleSettingsUi.page.tableHeaders.dailyLimit}</th>
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap text-right">${roleSettingsUi.page.tableHeaders.actions}</th>
              </tr>
            </thead>
            <tbody>
              <tr><td colspan="4" class="empty-cell">${roleSettingsUi.page.emptyRoleLimits}</td></tr>
            </tbody>
          </table>`;
        return;
      }

      container.innerHTML = `
        <table class="data-table w-full text-left border-collapse">
          <thead>
            <tr class="bg-porcelain-150 border-b border-graphite-180">
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">${roleSettingsUi.page.tableHeaders.roleName}</th>
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">${roleSettingsUi.page.tableHeaders.roleId}</th>
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">${roleSettingsUi.page.tableHeaders.dailyLimit}</th>
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap text-right">${roleSettingsUi.page.tableHeaders.actions}</th>
            </tr>
          </thead>
          <tbody>
            ${roleCache.map((r: RoleLimit) => {
              const isDefault = r.discordRoleId === "__default__";
              const limitText = r.dailyLimit === -1 ? roleSettingsUi.page.unlimitedLabel : r.dailyLimit + roleSettingsUi.page.perDaySuffix;
              const roleName = r.roleLabel || r.discordRoleId;
              const shortId = r.discordRoleId.length > 18
                ? r.discordRoleId.slice(0, 8) + "…" + r.discordRoleId.slice(-4)
                : r.discordRoleId;
              return `
                <tr class="border-b border-graphite-180 last:border-0 hover:bg-porcelain-150 transition-colors min-h-[48px]">
                  <td class="px-4 py-3 text-[14px]">
                    <span class="text-graphite-800 font-medium">${isDefault ? `<span class="status-badge badge-enabled">${roleSettingsUi.page.rowBadges.default}</span>` : roleName}</span>
                  </td>
                  <td class="px-4 py-3 text-[13px] text-graphite-500 mono">${shortId}</td>
                  <td class="px-4 py-3 text-[14px]">${limitText}</td>
                  <td class="px-4 py-3 text-right flex gap-2 justify-end">
                    ${isDefault
                      ? `<span class="text-graphite-400 text-[12px]">${roleSettingsUi.page.rowBadges.protected}</span>`
                      : `<button class="edit-role-btn bg-royal-blue-600 text-porcelain-50 px-3 py-1.5 rounded-button text-[13px] font-semibold hover:bg-royal-blue-700 transition-colors" data-role-id="${r.discordRoleId}">${roleSettingsUi.page.rowActions.edit}</button>
                      <button class="delete-role-btn bg-danger-600 text-porcelain-50 px-3 py-1.5 rounded-button text-[13px] font-semibold hover:bg-danger-700 transition-colors" data-role-id="${r.discordRoleId}">${roleSettingsUi.page.rowActions.delete}</button>`}
                  </td>
                </tr>`;
            }).join("")}
          </tbody>
        </table>`;

      // ── Bind Edit buttons ──
      container.querySelectorAll<HTMLElement>(".edit-role-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const roleId = btn.getAttribute("data-role-id");
          if (!roleId) return;
          const role = roleCache.find((r: RoleLimit) => r.discordRoleId === roleId);
          if (!role) return;
          openModal(role);
        });
      });

      // ── Bind Delete buttons ──
      container.querySelectorAll<HTMLElement>(".delete-role-btn").forEach((btn) => {
        btn.addEventListener("click", (e) => {
          e.stopPropagation();
          const roleId = btn.getAttribute("data-role-id");
          if (!roleId) return;
          if (!confirm(roleSettingsUi.page.alerts.deleteRoleLimitConfirm)) return;
          handleDelete(roleId);
        });
      });
    } catch (err: unknown) {
      console.error("[RoleLimits] renderTable error:", err);
    }
  }

  // ── Modal Controls ──
  function openModal(role: RoleLimit) {
    lastFocusedRoleTrigger = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    editingDiscordRoleId = role.discordRoleId;
    const title = getEl<HTMLHeadingElement>("role-modal-title");
    const idInput = getEl<HTMLInputElement>("role-id-input");
    const labelInput = getEl<HTMLInputElement>("role-label-input");
    const limitInput = getEl<HTMLInputElement>("role-limit-input");
    const modal = getEl("role-modal");

    if (!title || !idInput || !labelInput || !limitInput || !modal) return;

    title.textContent = role.discordRoleId === "__default__"
      ? roleSettingsUi.page.roleModalEditDefault
      : roleSettingsUi.page.roleModalEditPrefix + (role.roleLabel || role.discordRoleId);
    idInput.value = role.discordRoleId;
    idInput.disabled = true;
    labelInput.value = role.roleLabel ?? "";
    limitInput.value = String(role.dailyLimit);
    modal.classList.remove("hidden");
    setTimeout(() => limitInput.focus(), 50);
  }

  function closeModal() {
    editingDiscordRoleId = null;
    const modal = getEl("role-modal");
    const idInput = getEl<HTMLInputElement>("role-id-input");
    if (modal) modal.classList.add("hidden");
    if (idInput) idInput.disabled = false;
    lastFocusedRoleTrigger?.focus();
    lastFocusedRoleTrigger = null;
  }

  function openAddModal() {
    lastFocusedRoleTrigger = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    editingDiscordRoleId = null;
    const title = getEl<HTMLHeadingElement>("role-modal-title");
    const idInput = getEl<HTMLInputElement>("role-id-input");
    const labelInput = getEl<HTMLInputElement>("role-label-input");
    const limitInput = getEl<HTMLInputElement>("role-limit-input");
    const modal = getEl("role-modal");

    if (title) title.textContent = roleSettingsUi.page.roleModalAdd;
    if (idInput) { idInput.value = ""; idInput.disabled = false; }
    if (labelInput) labelInput.value = "";
    if (limitInput) limitInput.value = "";
    if (modal) modal.classList.remove("hidden");
    setTimeout(() => { if (idInput) idInput.focus(); }, 50);
  }

  // ── Save (Add or Edit) ──
  async function handleSave() {
    const roleIdEl = getEl<HTMLInputElement>("role-id-input");
    const labelEl = getEl<HTMLInputElement>("role-label-input");
    const limitEl = getEl<HTMLInputElement>("role-limit-input");

    if (!roleIdEl || !labelEl || !limitEl) return;

    const roleId = roleIdEl.value.trim();
    const roleLabel = labelEl.value.trim();
    const rawLimit = limitEl.value.trim();

    if (!roleId) { alert(roleSettingsUi.page.alerts.roleIdRequired); return; }
    if (rawLimit === "") { alert(roleSettingsUi.page.alerts.dailyLimitRequired); return; }

    const dailyLimit = parseInt(rawLimit, 10);
    if (!Number.isInteger(dailyLimit) || dailyLimit < -1 || dailyLimit === 0 || dailyLimit > 99999) {
      alert(roleSettingsUi.page.alerts.dailyLimitInvalid);
      return;
    }

    if (!csrfToken) { alert(roleSettingsUi.page.alerts.csrfUnavailableReload); return; }

    try {
      const body: Record<string, unknown> = {
        discordRoleId: roleId,
        roleLabel: roleLabel || null,
        dailyLimit,
      };
      if (editingDiscordRoleId) body.id = editingDiscordRoleId;

      const res = await fetch("/api/admin/role-limits", {
        method: "PUT",
        headers: { "Content-Type": "application/json", "x-csrf-token": csrfToken },
        body: JSON.stringify(body),
      });

      if (!res.ok) {
        const err: { error?: string } = await res.json().catch(() => ({ error: "Save failed" }));
        throw new Error(err.error || "Save failed (" + res.status + ")");
      }

      closeModal();
      await renderTable();
    } catch (err: unknown) {
      console.error("[RoleLimits] Save failed:", err);
      const msg = err instanceof Error ? err.message : "Failed to save role limit.";
      alert(msg);
    }
  }

  // ── Delete ──
  async function handleDelete(roleId: string) {
    if (!csrfToken) { alert(roleSettingsUi.page.alerts.csrfUnavailableReload); return; }

    try {
      const res = await fetch("/api/admin/role-limits?discordRoleId=" + encodeURIComponent(roleId), {
        method: "DELETE",
        headers: { "x-csrf-token": csrfToken },
      });

      if (!res.ok) {
        const err: { error?: string } = await res.json().catch(() => ({ error: "Delete failed" }));
        throw new Error(err.error || "Delete failed (" + res.status + ")");
      }

      await renderTable();
    } catch (err: unknown) {
      console.error("[RoleLimits] Delete failed:", err);
      const msg = err instanceof Error ? err.message : "Failed to delete role limit.";
      alert(msg);
    }
  }

  // ── Reset User Usage ──
  async function handleResetUsage() {
    const userIdEl = getEl<HTMLInputElement>("reset-user-id");
    const guildIdEl = getEl<HTMLInputElement>("reset-guild-id");
    const resultEl = getEl("reset-result");

    if (!userIdEl || !guildIdEl || !resultEl) return;

    const userId = userIdEl.value.trim();
    const guildId = guildIdEl.value.trim();

    if (!userId) { resultEl.textContent = roleSettingsUi.page.alerts.userIdRequired; resultEl.style.color = "var(--color-danger-600)"; return; }
    if (!guildId) { resultEl.textContent = roleSettingsUi.page.alerts.guildIdRequired; resultEl.style.color = "var(--color-danger-600)"; return; }
    if (!csrfToken) { resultEl.textContent = roleSettingsUi.page.alerts.csrfUnavailable; resultEl.style.color = "var(--color-danger-600)"; return; }

    try {
      const res = await fetch("/api/admin/role-limits/reset-usage", {
        method: "POST",
        headers: { "Content-Type": "application/json", "x-csrf-token": csrfToken },
        body: JSON.stringify({ userId, guildId }),
      });

      const body: { success?: boolean; affected?: number; error?: string } = await res.json().catch(() => ({ error: "Unknown error" }));

      if (!res.ok) {
        resultEl.textContent = roleSettingsUi.page.resetMessages.errorPrefix + (body.error || "Failed to reset usage.");
        resultEl.style.color = "var(--color-danger-600)";
        return;
      }

      resultEl.textContent = roleSettingsUi.page.resetMessages.successPrefix + userId + " (rows affected: " + (body.affected ?? 0) + ")";
      resultEl.style.color = "var(--color-royal-blue-600)";
    } catch (err: unknown) {
      console.error("[RoleLimits] Reset failed:", err);
      resultEl.textContent = roleSettingsUi.page.resetMessages.failed;
      resultEl.style.color = "var(--color-danger-600)";
    }
  }

  // ── Event Listeners ──
  const addBtn = getEl("add-role-btn");
  if (addBtn) addBtn.addEventListener("click", openAddModal);

  const editDefaultBtn = getEl("edit-default-btn");
  if (editDefaultBtn) {
    editDefaultBtn.addEventListener("click", () => {
      openModal({ discordRoleId: "__default__", roleLabel: null, dailyLimit: currentDefaultLimit } as RoleLimit);
    });
  }

  const cancelBtn = getEl("role-cancel-btn");
  if (cancelBtn) cancelBtn.addEventListener("click", closeModal);

  const closeBtn = getEl("role-modal-close");
  if (closeBtn) closeBtn.addEventListener("click", closeModal);

  const saveBtn = getEl("role-save-btn");
  if (saveBtn) saveBtn.addEventListener("click", handleSave);

  const resetBtn = getEl("reset-usage-btn");
  if (resetBtn) resetBtn.addEventListener("click", handleResetUsage);

  const modal = getEl("role-modal");
  if (modal) {
    modal.addEventListener("click", (e: Event) => {
      if (e.target === modal) closeModal();
    });
  }

  document.addEventListener("keydown", (e: KeyboardEvent) => {
    if (e.key === "Escape") closeModal();
  });

  // ── Role Bindings ──
  let bindingsCache: Array<{
    id: number;
    guildId: string;
    discordRoleId: string;
    outputBucketKey: string;
  }> = [];

  function formatOutputBucketLabel(value: string): string {
    return outputBucketLabels[value] ?? `Unknown: ${value}`;
  }

  function ensureOutputBucketOption(select: HTMLSelectElement, value: string) {
    const hasOption = Array.from(select.options).some((option) => option.value === value);
    if (hasOption) return;

    const option = document.createElement("option");
    option.value = value;
    option.textContent = formatOutputBucketLabel(value);
    select.appendChild(option);
  }

  async function renderBindings() {
    try {
      const res = await fetch('/api/admin/role-bindings');
      if (!res.ok) {
        const message = await res.text();
        throw new Error(`Failed to load bindings (${res.status}): ${message}`);
      }

      const data = await res.json();
      bindingsCache = data.bindings || [];

      const container = document.getElementById('bindings-container');
      if (!container) return;

      if (bindingsCache.length === 0) {
        container.innerHTML = `<div class="empty-state"><p>${roleSettingsUi.page.emptyBindings}</p></div>`;
        return;
      }

      container.innerHTML = `
        <table class="data-table w-full text-left border-collapse">
          <thead>
            <tr class="bg-porcelain-150 border-b border-graphite-180">
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium">${roleSettingsUi.page.tableHeaders.bindingRoleId}</th>
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium">${roleSettingsUi.page.tableHeaders.bindingBucket}</th>
              <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium text-right">${roleSettingsUi.page.tableHeaders.actions}</th>
            </tr>
          </thead>
          <tbody>
            ${bindingsCache.map((b) => `
              <tr class="border-b border-graphite-180 last:border-0 hover:bg-porcelain-150 transition-colors">
                <td class="px-4 py-3 text-[14px] text-graphite-800 font-medium mono">${b.discordRoleId}</td>
                <td class="px-4 py-3 text-[14px]"><span class="mono text-graphite-650">${formatOutputBucketLabel(b.outputBucketKey)}</span></td>
                <td class="px-4 py-3 text-[14px] text-right">
                  <button class="edit-binding-btn btn-ghost" data-id="${b.id}">${roleSettingsUi.page.bindingActions.edit}</button>
                  <button class="delete-binding-btn btn-danger-sm" data-id="${b.id}">${roleSettingsUi.page.bindingActions.delete}</button>
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      `;

      container.querySelectorAll('.edit-binding-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = Number(btn.getAttribute('data-id'));
          const binding = bindingsCache.find(b => b.id === id);
          if (!binding) return;
          lastFocusedBindingTrigger = document.activeElement instanceof HTMLElement ? document.activeElement : null;
          const nameInput = document.getElementById('binding-role-id') as HTMLInputElement | null;
          const keySelect = document.getElementById('binding-output-bucket') as HTMLSelectElement | null;
          if (nameInput && keySelect) {
            nameInput.value = binding.discordRoleId;
            ensureOutputBucketOption(keySelect, binding.outputBucketKey);
            keySelect.value = binding.outputBucketKey;
          }
          document.getElementById('binding-modal')?.classList.remove('hidden');
          nameInput?.focus();
        });
      });

      container.querySelectorAll('.delete-binding-btn').forEach(btn => {
        btn.addEventListener('click', async () => {
          const id = Number(btn.getAttribute('data-id'));
          if (!confirm(roleSettingsUi.page.alerts.deleteBindingConfirm)) return;
          if (!csrfToken) { alert(roleSettingsUi.page.alerts.csrfUnavailable); return; }
          try {
            const res = await fetch('/api/admin/role-bindings?id=' + id, {
              method: 'DELETE',
              headers: { 'x-csrf-token': csrfToken },
            });
            if (!res.ok) throw new Error('Delete failed');
            await renderBindings();
          } catch (err) {
            console.error('[RoleBindings] Delete failed:', err);
            alert('Failed to delete binding.');
          }
        });
      });
    } catch (err) {
      console.error('[RoleBindings] render error:', err);
    }
  }

  document.getElementById('add-binding-btn')?.addEventListener('click', () => {
    lastFocusedBindingTrigger = document.activeElement instanceof HTMLElement ? document.activeElement : null;
    const nameInput = document.getElementById('binding-role-id') as HTMLInputElement | null;
    const keySelect = document.getElementById('binding-output-bucket') as HTMLSelectElement | null;
    if (nameInput) nameInput.value = '';
    if (keySelect) keySelect.value = 'indonesian';
    document.getElementById('binding-modal')?.classList.remove('hidden');
    nameInput?.focus();
  });

  document.getElementById('binding-cancel-btn')?.addEventListener('click', () => {
    document.getElementById('binding-modal')?.classList.add('hidden');
    lastFocusedBindingTrigger?.focus();
    lastFocusedBindingTrigger = null;
  });

  document.getElementById('binding-save-btn')?.addEventListener('click', async () => {
    const nameInput = document.getElementById('binding-role-id') as HTMLInputElement | null;
    const keySelect = document.getElementById('binding-output-bucket') as HTMLSelectElement | null;
    if (!nameInput || !keySelect) return;

    const discordRoleId = nameInput.value.trim();
    const outputBucketKey = keySelect.value;
    if (!discordRoleId) { alert(roleSettingsUi.page.alerts.roleIdRequired); return; }

    if (!csrfToken) { alert(roleSettingsUi.page.alerts.csrfUnavailable); return; }
    try {
      const res = await fetch('/api/admin/role-bindings', {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
        body: JSON.stringify({ discordRoleId, outputBucketKey }),
      });
      if (!res.ok) throw new Error('Save failed');
      document.getElementById('binding-modal')?.classList.add('hidden');
      lastFocusedBindingTrigger?.focus();
      lastFocusedBindingTrigger = null;
      await renderBindings();
    } catch (err) {
      console.error('[RoleBindings] Save failed:', err);
      alert('Failed to save binding.');
    }
  });

  // ── Initial Load ──
  renderTable();
  renderBindings();
</script>

