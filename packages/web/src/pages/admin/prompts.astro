---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { generateCsrfToken } from "../../lib/csrf";
import { Button } from "../../components/admin/Button";

const session = getSession(Astro);
const csrfToken = session ? generateCsrfToken(session.discordUserId) : "";

if (!session?.isAdmin) {
  return Astro.redirect("/auth/login");
}
---

<meta name="csrf-token" content={csrfToken} />

<AdminLayout title="Prompts" active="prompts">
  <div class="page-header">
    <div>
      <h1 class="page-title">Prompt Versions</h1>
      <p class="page-description">Manage the LLM instructions that define how dictionary meanings are explained to learners.</p>
    </div>
    <Button variant="secondary" id="create-version-btn">
      Create New Version
    </Button>
  </div>

  <div id="prompts-container" class="table-container">
    <!-- Table will be hydrated by client-side script -->
  </div>

  <!-- Editor modal — fully static SSR HTML, managed by vanilla JS -->
  <div id="editor-modal" class="modal-overlay hidden">
    <div class="modal-content">
      <div class="editor-panel">
        <div class="editor-header">
          <h3 id="editor-title" class="editor-title">Edit <span id="editor-version-label" class="editor-version-label"></span></h3>
          <div class="editor-actions-top">
            <label class="editor-active-label">
              <input id="editor-active-checkbox" type="checkbox" class="editor-checkbox" />
              <span class="editor-checkbox-text">Set as active version</span>
            </label>
          </div>
        </div>

        <div class="editor-grid">
          <div class="editor-col">
            <label class="editor-col-label">Editor</label>
            <textarea id="editor-textarea" class="editor-textarea" spellcheck="false"></textarea>
          </div>
          <div class="editor-col">
            <label class="editor-col-label">Preview (Read-only)</label>
            <pre id="editor-preview" class="editor-preview"></pre>
          </div>
        </div>

        <div class="editor-footer">
          <button id="editor-cancel-btn" class="btn-secondary">Cancel</button>
          <button id="editor-save-btn" class="btn-primary">Save Changes</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import type { PromptVersion } from '../../lib/prompt-types';

    let versionsCache: PromptVersion[] = [];
    /** The id of the version currently being edited, or null for Create New Version */
    let editingId: string | null = null;

    // ── Render table ──
    async function renderTable() {
      try {
        const res = await fetch('/api/admin/prompts');
        const data = await res.json();
        versionsCache = data.versions || [];

        const container = document.getElementById('prompts-container');
        if (!container) return;

        container.innerHTML = `
          <table class="data-table w-full text-left border-collapse">
            <thead>
              <tr class="bg-porcelain-150 border-b border-graphite-180">
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">Version</th>
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">Last Updated</th>
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap">Status</th>
                <th class="px-4 py-3 text-[12px] uppercase text-graphite-500 font-medium whitespace-nowrap text-right">Actions</th>
              </tr>
            </thead>
            <tbody>
              ${versionsCache.map(v => {
                const isDefault = v.version === 'default';
                return `
                  <tr class="border-b border-graphite-180 last:border-0 hover:bg-porcelain-150 transition-colors min-h-[48px]">
                    <td class="px-4 py-3 text-[14px]"><span class="mono text-graphite-800 font-medium">${v.version}</span></td>
                    <td class="px-4 py-3 text-[14px] text-graphite-650 text-[13px]">${new Date(v.updatedAt).toLocaleString()}</td>
                    <td class="px-4 py-3 text-[14px]">${v.isActive ? '<span class="status-badge badge-enabled">Active</span>' : '<span class="status-badge badge-disabled">Inactive</span>'}</td>
                    <td class="px-4 py-3 text-[14px] text-right flex gap-2 justify-end">
                      <button class="edit-btn bg-royal-blue-600 text-porcelain-50 px-3 py-1.5 rounded-button text-[13px] font-semibold hover:bg-royal-blue-700 transition-colors" data-id="${v.id}">Edit</button>
                      ${!v.isActive ? `<button class="set-active-btn bg-porcelain-200 text-graphite-700 px-3 py-1.5 rounded-button text-[13px] font-semibold hover:bg-porcelain-300 transition-colors border border-graphite-300" data-id="${v.id}">Set Active</button>` : ''}
                      ${!isDefault ? `<button class="delete-btn bg-danger-600 text-porcelain-50 px-3 py-1.5 rounded-button text-[13px] font-semibold hover:bg-danger-800 transition-colors" data-id="${v.id}">Delete</button>` : ''}
                    </td>
                  </tr>
                `;
              }).join('')}
            </tbody>
          </table>
        `;

        // Bind Edit buttons
        document.querySelectorAll('.edit-btn').forEach(btn => {
          btn.addEventListener('click', (e) => {
            e.stopPropagation();
            const id = btn.getAttribute('data-id');
            const version = versionsCache.find(v => String(v.id) === String(id));
            if (version) openEditor(version);
          });
        });

        // Bind Set Active buttons
        document.querySelectorAll('.set-active-btn').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            e.stopPropagation();
            const id = btn.getAttribute('data-id');
            const version = versionsCache.find(v => String(v.id) === String(id));
            if (!version) return;
            try {
              const csrfRes = await fetch('/api/auth/csrf-token');
              const { token } = await csrfRes.json();
              const res = await fetch('/api/admin/prompts', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json', 'x-csrf-token': token },
                body: JSON.stringify({ id, content: version.content, isActive: true }),
              });
              if (!res.ok) throw new Error('Set Active failed (' + res.status + ')');
              await renderTable();
            } catch (err) {
              console.error('[Prompts] Set Active failed:', err);
              alert('Failed to set active version.');
            }
          });
        });

        // Bind Delete buttons
        document.querySelectorAll('.delete-btn').forEach(btn => {
          btn.addEventListener('click', async (e) => {
            e.stopPropagation();
            const id = btn.getAttribute('data-id');
            if (!confirm('Delete this prompt version? This cannot be undone.')) return;
            try {
              const csrfRes = await fetch('/api/auth/csrf-token');
              const { token } = await csrfRes.json();
              const res = await fetch('/api/admin/prompts?id=' + id, {
                method: 'DELETE',
                headers: { 'x-csrf-token': token },
              });
              if (!res.ok) {
                const err = await res.json().catch(() => ({ error: 'Delete failed' }));
                throw new Error(err.error || 'Delete failed (' + res.status + ')');
              }
              await renderTable();
            } catch (err) {
              console.error('[Prompts] Delete failed:', err);
              alert(err instanceof Error ? err.message : 'Delete failed.');
            }
          });
        });
      } catch (err) {
        console.error('[Prompts] renderTable error:', err);
      }
    }

    // ── Open / close editor ──
    function openEditor(version: PromptVersion) {
      editingId = version.id;
      const modal = document.getElementById('editor-modal');
      const textarea = document.getElementById('editor-textarea') as HTMLTextAreaElement | null;
      const preview = document.getElementById('editor-preview');
      const titleLabel = document.getElementById('editor-version-label');
      const checkbox = document.getElementById('editor-active-checkbox') as HTMLInputElement | null;
      if (!modal || !textarea || !preview || !titleLabel || !checkbox) return;

      titleLabel.textContent = version.version;
      textarea.value = version.content;
      preview.textContent = version.content;
      checkbox.checked = version.isActive;

      modal.classList.remove('hidden');
      textarea.focus();
    }

    function closeEditor() {
      editingId = null;
      const modal = document.getElementById('editor-modal');
      if (modal) modal.classList.add('hidden');
    }

    // ── Save handler ──
    async function handleSave() {
      const textarea = document.getElementById('editor-textarea') as HTMLTextAreaElement | null;
      const checkbox = document.getElementById('editor-active-checkbox') as HTMLInputElement | null;
      const saveBtn = document.getElementById('editor-save-btn') as HTMLButtonElement | null;
      if (!textarea || !checkbox || !saveBtn) return;

      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      try {
        const csrfRes = await fetch('/api/auth/csrf-token');
        const { token } = await csrfRes.json();

        const body: Record<string, unknown> = {
          content: textarea.value,
          isActive: checkbox.checked,
        };
        // id present → overwrite; absent → create new version
        if (editingId) body.id = editingId;

        const res = await fetch('/api/admin/prompts', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json', 'x-csrf-token': token },
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Save failed' }));
          throw new Error(err.error || 'Save failed (' + res.status + ')');
        }

        await renderTable();
        closeEditor();
      } catch (err) {
        console.error('[Prompts] Save failed:', err);
        alert('Failed to save prompt version. Please check the logs.');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';
      }
    }

    // ── Event listeners ──
    document.getElementById('create-version-btn')?.addEventListener('click', () => {
      editingId = null;
      const modal = document.getElementById('editor-modal');
      const textarea = document.getElementById('editor-textarea') as HTMLTextAreaElement | null;
      const preview = document.getElementById('editor-preview');
      const titleLabel = document.getElementById('editor-version-label');
      const checkbox = document.getElementById('editor-active-checkbox') as HTMLInputElement | null;
      if (!modal || !textarea || !preview || !titleLabel || !checkbox) return;

      titleLabel.textContent = '';
      textarea.value = '';
      preview.textContent = '';
      checkbox.checked = true;

      modal.classList.remove('hidden');
      textarea.focus();
    });

    document.getElementById('editor-cancel-btn')?.addEventListener('click', closeEditor);
    document.getElementById('editor-save-btn')?.addEventListener('click', handleSave);

    document.getElementById('editor-modal')?.addEventListener('click', (e) => {
      if (e.target === document.getElementById('editor-modal')) closeEditor();
    });

    // Keyboard shortcut: Escape to close, Ctrl+Enter to save
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeEditor();
      if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') handleSave();
    });

    // Update preview on textarea input
    document.getElementById('editor-textarea')?.addEventListener('input', () => {
      const textarea = document.getElementById('editor-textarea') as HTMLTextAreaElement | null;
      const preview = document.getElementById('editor-preview');
      if (textarea && preview) preview.textContent = textarea.value;
    });

    // Initial load
    renderTable();
  </script>

  <style>
    .page-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      margin-bottom: 24px;
    }
    .page-title {
      font-size: 20px;
      line-height: 1.3;
      font-weight: 600;
      color: var(--color-graphite-800);
      margin: 0;
    }
    .page-description {
      margin: 4px 0 0;
      font-size: 13px;
      color: var(--color-graphite-500);
    }
    .table-container {
      background: var(--color-porcelain-100);
      border: 1px solid var(--color-graphite-180);
      border-radius: var(--radius-card);
      overflow: hidden;
    }

    /* Modal */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 1000;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px;
    }
    .modal-content {
      background: var(--color-porcelain-50);
      border-radius: var(--radius-panel);
      max-width: 1100px;
      width: 100%;
      max-height: 90vh;
      overflow-y: auto;
      padding: 24px;
      border: 1px solid var(--color-graphite-300);
    }
    .hidden { display: none !important; }

    /* Editor */
    .editor-panel {
      display: flex;
      flex-direction: column;
      gap: 24px;
      background: var(--color-porcelain-100);
      border: 1px solid var(--color-graphite-180);
      border-radius: var(--radius-panel);
      padding: 24px;
    }
    .editor-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .editor-title {
      font-size: 20px;
      font-weight: 600;
      color: var(--color-graphite-800);
      margin: 0;
      letter-spacing: -0.01em;
    }
    .editor-version-label {
      color: var(--color-royal-blue-600);
    }
    .editor-active-label {
      display: flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }
    .editor-checkbox {
      width: 16px;
      height: 16px;
      border-radius: 4px;
      border: 1px solid var(--color-graphite-300);
      accent-color: var(--color-royal-blue-600);
    }
    .editor-checkbox-text {
      font-size: 14px;
      font-weight: 500;
      color: var(--color-graphite-650);
    }
    .editor-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 24px;
    }
    .editor-col {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .editor-col-label {
      font-size: 13px;
      font-weight: 500;
      text-transform: uppercase;
      color: var(--color-graphite-500);
      letter-spacing: 0.01em;
    }
    .editor-textarea {
      width: 100%;
      height: 400px;
      padding: 16px;
      border-radius: var(--radius-button);
      background: var(--color-porcelain-50);
      border: 1px solid var(--color-graphite-300);
      color: var(--color-graphite-900);
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.5;
      resize: none;
      outline: none;
      transition: border-color 0.15s, box-shadow 0.15s;
      box-sizing: border-box;
    }
    .editor-textarea:focus {
      border-color: var(--color-royal-blue-600);
      box-shadow: 0 0 0 2px var(--color-royal-blue-100);
    }
    .editor-preview {
      width: 100%;
      height: 400px;
      padding: 16px;
      border-radius: var(--radius-button);
      background: var(--color-graphite-900);
      color: var(--color-porcelain-50);
      font-family: var(--font-mono);
      font-size: 13px;
      line-height: 1.5;
      overflow-y: auto;
      white-space: pre-wrap;
      word-break: break-word;
      margin: 0;
      box-sizing: border-box;
    }
    .editor-footer {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
    }

    /* Buttons */
    .btn-primary {
      background: var(--color-royal-blue-600);
      color: var(--color-porcelain-50);
      padding: 8px 20px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 600;
      border: none;
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-primary:hover { background: var(--color-royal-blue-700); }
    .btn-primary:disabled { opacity: 0.5; cursor: not-allowed; }

    .btn-secondary {
      background: var(--color-porcelain-200);
      color: var(--color-graphite-700);
      padding: 8px 20px;
      border-radius: var(--radius-button);
      font-size: 14px;
      font-weight: 600;
      border: 1px solid var(--color-graphite-300);
      cursor: pointer;
      transition: background 0.15s;
    }
    .btn-secondary:hover { background: var(--color-porcelain-300); }
  </style>
</AdminLayout>
