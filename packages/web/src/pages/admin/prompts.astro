---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { getSession } from "../../lib/session";
import { generateCsrfToken } from "../../lib/csrf";
import { WEBUI_CONFIG } from "../../config/webui";

const promptsUi = WEBUI_CONFIG.prompts;

const session = getSession(Astro);
const csrfToken = session ? generateCsrfToken(session.discordUserId) : "";

if (!session?.isAdmin) {
  return Astro.redirect("/auth/login");
}
---

<AdminLayout title={promptsUi.page.title} active="prompts" csrfToken={csrfToken}>
  <div class="prompt-page">
    <div class="page-header">
      <div>
        <p class="page-kicker">{promptsUi.page.libraryLabel}</p>
        <h1 class="page-title">{promptsUi.page.title}</h1>
        <p class="page-description">{promptsUi.page.description}</p>
      </div>
    </div>

    <div class="prompt-layout">
      <aside class="scope-rail" aria-label="Prompt scopes">
        <div class="rail-heading">
          <p class="card-kicker">{promptsUi.page.scopeNavigatorLabel}</p>
          <p class="rail-note">{promptsUi.page.scopeNavigatorNote}</p>
        </div>
        <div id="scope-rail-list" class="scope-list"></div>
      </aside>

      <section class="scope-workspace">
        <header class="workspace-hero">
          <div>
            <p class="card-kicker">{promptsUi.page.selectedScopeLabel}</p>
            <h2 id="scope-title" class="scope-title">{promptsUi.page.baselineLabel}</h2>
            <p id="scope-description" class="scope-description">{promptsUi.page.baselineVersionName}</p>
          </div>
          <div class="scope-hero-meta">
            <div class="hero-chip" id="scope-resolution-chip">{promptsUi.page.runtimeFallback}</div>
            <div class="hero-chip hero-chip-secondary" id="scope-version-chip">{promptsUi.page.noActiveVersion}</div>
          </div>
        </header>

        <div class="versions-card">
          <div class="versions-card-header">
            <div>
              <p class="card-kicker">{promptsUi.page.versionHistoryLabel}</p>
              <h3 id="versions-title" class="versions-title">{promptsUi.page.baselineLabel}</h3>
            </div>
            <div class="versions-actions">
              <button id="scope-reset-btn" class="action-btn action-btn-secondary" type="button">{promptsUi.page.resetOverride}</button>
              <button id="scope-create-btn" class="action-btn action-btn-primary" type="button">{promptsUi.page.createVersion}</button>
            </div>
          </div>

          <div id="versions-empty" class="empty-state hidden">
            <div class="empty-state-body">
              <p class="empty-title">{promptsUi.page.noOverride}</p>
              <p class="empty-copy">{promptsUi.page.noOverrideCopy}</p>
              <button id="empty-create-btn" class="action-btn action-btn-primary" type="button">{promptsUi.page.createOverrideVersion}</button>
            </div>
          </div>

          <div id="versions-container" class="versions-table-wrap"></div>
        </div>

        <div class="reference-grid">
          <details class="reference-card">
            <summary class="reference-summary">{promptsUi.page.templateVariablesLabel}</summary>
            <table class="reference-table">
              <thead>
                <tr>
                  <th>{promptsUi.page.referenceTableHeaders.variable}</th>
                  <th>{promptsUi.page.referenceTableHeaders.description}</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td class="reference-code">{promptsUi.variables[0].name}</td>
                  <td>Output bucket used for routing: <span class="mono">daily-japanese</span> or <span class="mono">indonesian</span></td>
                </tr>
                {promptsUi.variables.slice(1).map((variable: { name: string; description: string }) => (
                  <tr>
                    <td class="reference-code">{variable.name}</td>
                    <td>{variable.description}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </details>

          <details class="reference-card">
            <summary class="reference-summary">{promptsUi.page.routingContractLabel}</summary>
            <ul class="reference-list">
              {promptsUi.routing.map((line: string) => <li>{line}</li>)}
            </ul>
          </details>
        </div>
      </section>
    </div>
  </div>

  <div id="editor-modal" class="editor-modal hidden" aria-hidden="true">
    <div class="editor-modal-backdrop"></div>
    <div class="editor-modal-surface" role="dialog" aria-modal="true" aria-labelledby="editor-title">
      <div class="editor-shell">
        <div class="editor-header">
          <div>
            <p class="card-kicker" id="editor-scope-label">{promptsUi.page.editorScopeLabel}</p>
            <h3 id="editor-title" class="editor-title">{promptsUi.page.editVersion}</h3>
            <p id="editor-version-hint" class="editor-hint"></p>
          </div>
          <label class="editor-active-label">
            <input id="editor-active-checkbox" type="checkbox" class="editor-checkbox" />
            <span>{promptsUi.page.activeVersionLabel}</span>
          </label>
        </div>

        <div class="editor-toolbar">
          <button id="editor-edit-btn" class="editor-toolbar-btn active" type="button">
            <svg class="editor-toolbar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/><path d="m15 5 4 4"/></svg>
            <span>Edit</span>
          </button>
          <button id="editor-preview-btn" class="editor-toolbar-btn" type="button">
            <svg class="editor-toolbar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            <span>Preview</span>
          </button>
        </div>
        <div class="editor-content">
          <label class="editor-col-label" for="editor-textarea">{promptsUi.page.editorLabel}</label>
          <textarea id="editor-textarea" class="editor-textarea" spellcheck="false"></textarea>
          <div id="editor-preview" class="editor-preview" hidden></div>
        </div>

        <div class="editor-footer">
          <button id="editor-cancel-btn" class="action-btn action-btn-secondary" type="button">{promptsUi.page.cancel}</button>
          <button id="editor-save-btn" class="action-btn action-btn-primary" type="button">{promptsUi.page.save}</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { WEBUI_CONFIG } from '../../config/webui';
    import type { PromptScopeView, PromptVersion } from '../../lib/prompt-types';

    const promptsUi = WEBUI_CONFIG.prompts;

    const scopeRailList = document.getElementById('scope-rail-list') as HTMLElement | null;
    const scopeTitle = document.getElementById('scope-title') as HTMLElement | null;
    const scopeDescription = document.getElementById('scope-description') as HTMLElement | null;
    const scopeResolutionChip = document.getElementById('scope-resolution-chip') as HTMLElement | null;
    const scopeVersionChip = document.getElementById('scope-version-chip') as HTMLElement | null;
    const versionsTitle = document.getElementById('versions-title') as HTMLElement | null;
    const versionsContainer = document.getElementById('versions-container') as HTMLElement | null;
    const versionsEmpty = document.getElementById('versions-empty') as HTMLElement | null;
    const scopeCreateBtn = document.getElementById('scope-create-btn') as HTMLButtonElement | null;
    const emptyCreateBtn = document.getElementById('empty-create-btn') as HTMLButtonElement | null;
    const scopeResetBtn = document.getElementById('scope-reset-btn') as HTMLButtonElement | null;
    const editorModal = document.getElementById('editor-modal') as HTMLElement | null;
    const editorBackdrop = document.querySelector('.editor-modal-backdrop') as HTMLElement | null;
    const editorScopeLabel = document.getElementById('editor-scope-label') as HTMLElement | null;
    const editorTitle = document.getElementById('editor-title') as HTMLElement | null;
    const editorVersionHint = document.getElementById('editor-version-hint') as HTMLElement | null;
    const editorTextarea = document.getElementById('editor-textarea') as HTMLTextAreaElement | null;
    const editorPreview = document.getElementById('editor-preview') as HTMLElement | null;
    const editorActiveCheckbox = document.getElementById('editor-active-checkbox') as HTMLInputElement | null;
    const editorCancelBtn = document.getElementById('editor-cancel-btn') as HTMLButtonElement | null;
    const editorSaveBtn = document.getElementById('editor-save-btn') as HTMLButtonElement | null;
    const editorEditBtn = document.getElementById('editor-edit-btn') as HTMLButtonElement | null;
    const editorPreviewBtn = document.getElementById('editor-preview-btn') as HTMLButtonElement | null;

    let promptScopes: PromptScopeView[] = [];
    let selectedScopeKey: string = '';
    let defaultBaseline: PromptVersion | null = null;
    let editingId: string | null = null;
    let lastFocusedTrigger: HTMLElement | null = null;

    function escapeHtml(value: string): string {
      return String(value)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    function selectedScope(): PromptScopeView | null {
      return promptScopes.find((scope) => scope.scopeKey === selectedScopeKey) ?? promptScopes[0] ?? null;
    }

    function runtimeStateText(scope: PromptScopeView | null): string {
      if (!scope) return promptsUi.page.loading;
      if (scope.inheritedFromDefault) return promptsUi.page.inheritedFromDefault;
      if (scope.resolvedPrompt) return `${promptsUi.page.activeVersionPrefix}${scope.resolvedPrompt.version}`;
      return promptsUi.page.noActiveVersion;
    }

    function scopeCardState(scope: PromptScopeView): string {
      return scope.inheritedFromDefault ? promptsUi.page.scopeCardInherited : promptsUi.page.scopeCardOverrideActive;
    }

    function renderScopeRail(): void {
      if (!scopeRailList) return;

      scopeRailList.innerHTML = promptScopes.map((scope) => {
        const selected = scope.scopeKey === selectedScopeKey;
        const activeVersion = scope.resolvedPrompt ? escapeHtml(scope.resolvedPrompt.version) : promptsUi.page.noActiveVersion;
        const versionCount = scope.versions.length;
        const state = scopeCardState(scope);
        const accentClass = scope.inheritedFromDefault ? 'scope-card-accent-default' : 'scope-card-accent-override';

        return `
          <button type="button" class="scope-card ${selected ? 'scope-card-selected' : ''}" data-scope-key="${escapeHtml(scope.scopeKey)}" ${selected ? 'aria-current="true"' : ''}>
            <span class="scope-card-accent ${accentClass}"></span>
            <div class="scope-card-body">
              <div class="scope-card-header">
                <div class="scope-card-label-wrap">
                  <p class="scope-card-label">${escapeHtml(scope.scopeLabel)}</p>
                  <p class="scope-card-description">${escapeHtml(scope.scopeDescription)}</p>
                </div>
                <span class="scope-badge ${scope.inheritedFromDefault ? 'scope-badge-default' : 'scope-badge-override'}">${escapeHtml(state)}</span>
              </div>
              <div class="scope-card-footer">
                <span class="scope-card-count">${versionCount} version${versionCount === 1 ? '' : 's'}</span>
                <span class="scope-card-runtime">${activeVersion}</span>
              </div>
            </div>
          </button>
        `;
      }).join('');

      scopeRailList.querySelectorAll('[data-scope-key]').forEach((button) => {
        button.addEventListener('click', () => {
          const scopeKey = button.getAttribute('data-scope-key');
          if (!scopeKey) return;
          selectedScopeKey = scopeKey;
          renderAll();
        });
      });
    }

    function renderWorkspace(): void {
      const scope = selectedScope();
      if (!scope) return;

      if (scopeTitle) scopeTitle.textContent = scope.scopeLabel;
      if (scopeDescription) scopeDescription.textContent = scope.scopeDescription;
      if (scopeResolutionChip) scopeResolutionChip.textContent = runtimeStateText(scope);
      if (scopeVersionChip) {
        if (scope.inheritedFromDefault && scope.resolvedPrompt) {
          scopeVersionChip.textContent = `${promptsUi.page.inheritedFromDefault} · ${promptsUi.page.runtimeVersionPrefix}${scope.resolvedPrompt.version}`;
        } else if (scope.resolvedPrompt) {
          scopeVersionChip.textContent = `${promptsUi.page.runtimeVersionPrefix}${scope.resolvedPrompt.version}`;
        } else {
          scopeVersionChip.textContent = promptsUi.page.noActiveVersion;
        }
      }
      if (versionsTitle) versionsTitle.textContent = `${scope.scopeLabel} versions`;
      if (scopeResetBtn) scopeResetBtn.hidden = scope.versions.length === 0;

      if (scopeCreateBtn) scopeCreateBtn.textContent = promptsUi.page.createOverrideVersion;
      if (emptyCreateBtn) emptyCreateBtn.textContent = promptsUi.page.createOverrideVersion;

      if (!versionsContainer || !versionsEmpty) return;

      if (scope.versions.length === 0) {
        versionsEmpty.classList.remove('hidden');
        versionsContainer.innerHTML = '';
        return;
      }

      versionsEmpty.classList.add('hidden');
      const baselineRow = defaultBaseline ? `
        <article class="version-card version-card-baseline">
          <div class="version-card-mark version-card-mark-baseline">BL</div>
          <div class="version-card-main">
            <div class="version-card-head">
              <span class="version-name">${escapeHtml(defaultBaseline.version)}</span>
              <span class="version-scope">${escapeHtml(promptsUi.page.baselineVersionName)}</span>
            </div>
            <p class="version-card-updated">${new Date(defaultBaseline.updatedAt).toLocaleString()}</p>
          </div>
          <div class="version-card-side">
            <div class="version-card-status">
              <span class="row-badge row-badge-active">${escapeHtml(promptsUi.page.baselineLabel)}</span>
            </div>
            <div class="version-card-actions">
              <span class="version-card-baseline-note">${escapeHtml(promptsUi.page.inheritedFromDefault)}</span>
            </div>
          </div>
        </article>
      ` : '';

      versionsContainer.innerHTML = baselineRow + `
        <div class="version-list">
          ${scope.versions.map((version, index) => {
            const statusLabel = version.isActive ? promptsUi.page.status.active : promptsUi.page.status.inactive;
            const versionNumber = String(index + 1).padStart(2, '0');
            return `
              <article class="version-card ${version.isActive ? 'version-card-active' : ''}">
                <div class="version-card-mark">${versionNumber}</div>
                <div class="version-card-main">
                  <div class="version-card-head">
                    <span class="version-name">${escapeHtml(version.version)}</span>
                    <span class="version-scope">${escapeHtml(version.scopeKey)}</span>
                  </div>
                  <p class="version-card-updated">${new Date(version.updatedAt).toLocaleString()}</p>
                </div>
                <div class="version-card-side">
                  <div class="version-card-status">
                    <span class="row-badge ${version.isActive ? 'row-badge-active' : 'row-badge-inactive'}">${escapeHtml(statusLabel)}</span>
                  </div>
                  <div class="version-card-actions">
                    <button type="button" class="table-btn table-btn-primary" data-action="edit" data-id="${escapeHtml(version.id)}">${promptsUi.page.edit}</button>
                    <button type="button" class="table-btn table-btn-secondary" data-action="activate" data-id="${escapeHtml(version.id)}" ${version.isActive ? 'disabled' : ''}>${promptsUi.page.activate}</button>
                    <button type="button" class="table-btn table-btn-danger" data-action="delete" data-id="${escapeHtml(version.id)}">${promptsUi.page.delete}</button>
                  </div>
                </div>
              </article>
            `;
          }).join('')}
        </div>
      `;

      versionsContainer.querySelectorAll('[data-action]').forEach((button) => {
        button.addEventListener('click', async () => {
          const action = button.getAttribute('data-action');
          const id = button.getAttribute('data-id');
          if (!action || !id) return;

          const version = scope.versions.find((item) => item.id === id);
          if (!version) return;

          if (action === 'edit') {
            openEditor(version, 'edit');
          }

          if (action === 'activate') {
            await activateVersion(version);
          }

          if (action === 'delete') {
            await deleteVersion(version);
          }
        });
      });
    }

    function renderAll(): void {
      renderScopeRail();
      renderWorkspace();
    }

    function openEditor(version: PromptVersion | null, mode: 'edit' | 'create' = 'edit'): void {
      const scope = selectedScope();
      if (!scope || !editorModal || !editorScopeLabel || !editorTitle || !editorVersionHint || !editorTextarea || !editorPreview || !editorActiveCheckbox || !editorEditBtn || !editorPreviewBtn) return;

      lastFocusedTrigger = document.activeElement instanceof HTMLElement ? document.activeElement : null;
      editingId = version ? version.id : null;
      const seedVersion = version ?? scope.resolvedPrompt;
      const scopeLabel = scope.scopeLabel;

      editorScopeLabel.textContent = scopeLabel;
      editorTitle.textContent = mode === 'create' ? promptsUi.page.createPromptVersion : promptsUi.page.editPromptVersion;
      editorVersionHint.textContent = mode === 'create'
        ? (seedVersion ? `Cloning ${seedVersion.version} into ${scope.scopeKey}` : `New version · ${scope.scopeKey}`)
        : (seedVersion ? `Version ${seedVersion.version} · ${scope.scopeKey}` : `Version · ${scope.scopeKey}`);
      editorTextarea.value = seedVersion ? seedVersion.content : '';
      editorPreview.textContent = escapeHtml(editorTextarea.value);
      editorActiveCheckbox.checked = version ? version.isActive : true;

      // Set to edit mode by default
      setEditorMode('edit');

      editorModal.classList.remove('hidden');
      editorModal.setAttribute('aria-hidden', 'false');
      editorTextarea.focus();
    }

    function setEditorMode(mode: 'edit' | 'preview'): void {
      if (!editorTextarea || !editorPreview || !editorEditBtn || !editorPreviewBtn) return;

      const isEdit = mode === 'edit';
      editorTextarea.hidden = !isEdit;
      editorPreview.hidden = isEdit;

      editorEditBtn.classList.toggle('active', isEdit);
      editorPreviewBtn.classList.toggle('active', !isEdit);
    }

    function closeEditor(): void {
      editingId = null;
      if (!editorModal) return;
      editorModal.classList.add('hidden');
      editorModal.setAttribute('aria-hidden', 'true');
      lastFocusedTrigger?.focus();
      lastFocusedTrigger = null;
    }

    async function csrfHeaders(): Promise<Record<string, string>> {
      const token = document.querySelector('meta[name="csrf-token"]')?.getAttribute('content') ?? '';
      return token ? { 'Content-Type': 'application/json', 'x-csrf-token': token } : { 'Content-Type': 'application/json' };
    }

    async function saveEditor(): Promise<void> {
      const scope = selectedScope();
      if (!scope || !editorTextarea || !editorActiveCheckbox || !editorSaveBtn) return;
      if (!editorModal || editorModal.classList.contains('hidden')) return;

      editorSaveBtn.disabled = true;
      editorSaveBtn.textContent = promptsUi.page.saving;

      try {
        const body: Record<string, unknown> = {
          content: editorTextarea.value,
          isActive: editorActiveCheckbox.checked,
        };

        if (editingId) {
          body.id = editingId;
        } else {
          body.scopeKey = scope.scopeKey;
        }

        const res = await fetch('/api/admin/prompts', {
          method: 'PUT',
          headers: await csrfHeaders(),
          body: JSON.stringify(body),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Save failed' }));
          throw new Error(err.error || `Save failed (${res.status})`);
        }

        await loadPromptScopes();
        closeEditor();
      } catch (err) {
        console.error('[Prompts] Save failed:', err);
        alert(err instanceof Error ? err.message : promptsUi.page.failedToSave);
      } finally {
        editorSaveBtn.disabled = false;
        editorSaveBtn.textContent = promptsUi.page.save;
      }
    }

    async function deleteVersion(version: PromptVersion): Promise<void> {
      if (!confirm(`${promptsUi.page.deleteConfirmPrefix}${version.version}${promptsUi.page.deleteConfirmSuffix}`)) return;

      try {
        const res = await fetch(`/api/admin/prompts?id=${encodeURIComponent(version.id)}`, {
          method: 'DELETE',
          headers: await csrfHeaders(),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Delete failed' }));
          throw new Error(err.error || `Delete failed (${res.status})`);
        }

        await loadPromptScopes();
      } catch (err) {
        console.error('[Prompts] Delete failed:', err);
        alert(err instanceof Error ? err.message : 'Failed to delete prompt version.');
      }
    }

    async function activateVersion(version: PromptVersion): Promise<void> {
      try {
        const res = await fetch('/api/admin/prompts', {
          method: 'PUT',
          headers: await csrfHeaders(),
          body: JSON.stringify({
            id: version.id,
            content: version.content,
            isActive: true,
          }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Activate failed' }));
          throw new Error(err.error || `Activate failed (${res.status})`);
        }

        await loadPromptScopes();
      } catch (err) {
        console.error('[Prompts] Activate failed:', err);
        alert(err instanceof Error ? err.message : 'Failed to activate prompt version.');
      }
    }

    async function resetOverride(): Promise<void> {
      const scope = selectedScope();
      if (!scope) return;

      if (!confirm(`${promptsUi.page.resetOverrideConfirmPrefix}${scope.scopeLabel}${promptsUi.page.resetOverrideConfirmSuffix}`)) return;

      try {
        const res = await fetch(`/api/admin/prompts?scope=${encodeURIComponent(scope.scopeKey)}`, {
          method: 'DELETE',
          headers: await csrfHeaders(),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({ error: 'Reset failed' }));
          throw new Error(err.error || `Reset failed (${res.status})`);
        }

        await loadPromptScopes();
      } catch (err) {
        console.error('[Prompts] Reset override failed:', err);
        alert(err instanceof Error ? err.message : 'Failed to reset override.');
      }
    }

    async function loadPromptScopes(): Promise<void> {
      try {
        const res = await fetch('/api/admin/prompts');
        const data: { scopes?: PromptScopeView[]; defaultBaseline?: PromptVersion | null } = await res.json();
        const allScopes = data.scopes ?? [];
        promptScopes = allScopes.filter((scope) => scope.scopeKey !== 'default');
        defaultBaseline = data.defaultBaseline ?? null;

        if (promptScopes.length === 0) {
          throw new Error('No prompt scopes returned');
        }

        if (!promptScopes.some((scope) => scope.scopeKey === selectedScopeKey)) {
          selectedScopeKey = promptScopes[0]!.scopeKey;
        }

        renderAll();
      } catch (err) {
        console.error('[Prompts] loadPromptScopes failed:', err);
        if (scopeRailList) {
          scopeRailList.innerHTML = `
            <div class="error-card">
              <p class="empty-title">${promptsUi.page.loadErrorTitle}</p>
              <p class="empty-copy">${promptsUi.page.loadErrorCopy}</p>
            </div>
          `;
        }
      }
    }

    scopeCreateBtn?.addEventListener('click', () => openEditor(null, 'create'));
    emptyCreateBtn?.addEventListener('click', () => openEditor(null, 'create'));
    scopeResetBtn?.addEventListener('click', resetOverride);
    editorCancelBtn?.addEventListener('click', closeEditor);
    editorSaveBtn?.addEventListener('click', saveEditor);
    editorBackdrop?.addEventListener('click', closeEditor);

    // Toolbar toggle
    editorEditBtn?.addEventListener('click', () => setEditorMode('edit'));
    editorPreviewBtn?.addEventListener('click', () => setEditorMode('preview'));

    loadPromptScopes();
  </script>

  <style>
    .prompt-page {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 20px;
    }

    .page-kicker,
    .card-kicker {
      margin: 0 0 6px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--color-graphite-500);
    }

    .page-title {
      margin: 0;
      font-size: clamp(28px, 3vw, 40px);
      line-height: 1.05;
      font-weight: 650;
      letter-spacing: -0.03em;
      color: var(--color-graphite-900);
    }

    .page-description {
      margin: 8px 0 0;
      max-width: 68ch;
      font-size: 14px;
      line-height: 1.7;
      color: var(--color-graphite-600);
    }

    .action-btn {
      border-radius: 999px;
      padding: 11px 18px;
      font-size: 14px;
      font-weight: 650;
      border: 1px solid transparent;
      cursor: pointer;
      transition: transform 0.16s ease, background 0.16s ease, border-color 0.16s ease, color 0.16s ease;
    }

    .action-btn:hover {
      transform: translateY(-1px);
    }

    .action-btn:active {
      transform: translateY(0) scale(0.985);
    }

    .action-btn:disabled {
      opacity: 0.5;
      cursor: not-allowed;
      transform: none;
    }

    .action-btn-primary {
      background: var(--color-royal-blue-600);
      color: var(--color-porcelain-50);
      border-color: var(--color-royal-blue-700);
    }

    .action-btn-primary:hover {
      background: var(--color-royal-blue-700);
    }

    .action-btn-secondary {
