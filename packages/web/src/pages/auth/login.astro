---
import "../../styles/globals.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — GRKD-Jisho Admin</title>
  </head>
  <body class="bg-porcelain-50 min-h-dvh flex flex-col items-center justify-center font-grkd-sans">
    <main class="w-full max-w-2xl px-6 flex flex-col items-center">
      <div class="mb-12 text-center">
        <h1 class="text-display font-bold text-graphite-800 tracking-tight mb-4">GRKD-Jisho Admin</h1>
        <p class="text-body text-graphite-650 max-w-lg mx-auto">
          The central command for the Indonesian-Japanese dictionary bot.
          Enter your authenticator code to log in.
        </p>
      </div>

      <!-- Loading indicator (shown while checking setup status) -->
      <div id="loading" class="text-body-sm text-graphite-500 mb-6">
        Checking authentication setup…
      </div>

      <!-- Login form (hidden initially, shown after status check) -->
      <div id="loginContainer" class="hidden w-full max-w-md bg-porcelain-100 border border-graphite-180 rounded-panel p-8 shadow-sm">
        <div class="mb-8">
          <h2 class="text-heading-sm font-semibold text-graphite-800 mb-6">Quick Access Guide</h2>
          <ol class="space-y-4 text-body-sm text-graphite-650">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-royal-blue-100 text-royal-blue-700 flex items-center justify-center text-xs font-semibold border border-royal-blue-600">1</span>
              <span>Open your authenticator app</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-royal-blue-100 text-royal-blue-700 flex items-center justify-center text-xs font-semibold border border-royal-blue-600">2</span>
              <span>Enter the 6-digit code for <strong>GRKD-Jisho Admin</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-royal-blue-100 text-royal-blue-700 flex items-center justify-center text-xs font-semibold border border-royal-blue-600">3</span>
              <span>Manage dictionaries and settings</span>
            </li>
          </ol>
        </div>

        <form id="loginForm">
          <label for="totpCode" class="block text-body-sm font-medium text-graphite-700 mb-2">
            Authenticator Code
          </label>
          <input
            id="totpCode"
            type="text"
            inputmode="numeric"
            pattern="[0-9]{6}"
            maxlength="6"
            autocomplete="one-time-code"
            placeholder="000000"
            class="w-full text-center text-heading-sm font-bold font-grkd-mono tracking-widest bg-porcelain-50 border border-graphite-250 rounded-button px-4 py-3 text-graphite-800 placeholder:text-graphite-400 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-royal-blue-600 focus-visible:border-royal-blue-600 mb-4"
          />
          <button
            type="submit"
            class="w-full bg-royal-blue-600 text-porcelain-50 border border-royal-blue-700 hover:bg-royal-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-royal-blue-600 focus-visible:ring-offset-2 focus-visible:ring-offset-porcelain-100 rounded-button px-6 py-3 text-body-sm font-semibold transition-colors shadow-sm cursor-pointer"
          >
            Log In
          </button>
          <p id="loginError" class="hidden text-danger-600 text-body-sm mt-4 text-center"></p>
        </form>

        <p class="mt-6 text-center text-caption text-graphite-500">
          Lost access to your authenticator app?
          <a href="/auth/logout" class="text-royal-blue-600 hover:text-royal-blue-700 underline">Log out</a> and run <code class="font-grkd-mono text-caption">pnpm auth:reset</code> on the server to reconfigure.
        </p>
      </div>

      <footer class="mt-16 text-center text-caption text-graphite-500">
        <p class="mb-1">GRKD-Jisho Admin &bull; v0.1.0</p>
        <p class="opacity-60">Powered by GoRakuDo</p>
      </footer>
    </main>

    <script>
      (async () => {
        const loading = document.getElementById("loading");
        const loginContainer = document.getElementById("loginContainer");
        const loginForm = document.getElementById("loginForm");
        const loginError = document.getElementById("loginError");

        if (!loading || !loginContainer || !loginForm || !loginError) return;

        try {
          const res = await fetch("/api/auth/status");
          const data = await res.json();

          if (data.setupRequired) {
            window.location.href = "/auth/setup";
            return;
          }

          // TOTP is set up — show login form
          loading.classList.add("hidden");
          loginContainer.classList.remove("hidden");
        } catch (err) {
          loading.innerHTML = 'Failed to connect. <a href="/auth/login" class="text-royal-blue-600 underline">Retry</a>.';
          console.error("[TOTP/Login] Status check failed:", err);
          return;
        }

        // Handle form submission
        loginForm.addEventListener("submit", async (e) => {
          e.preventDefault();

          const codeInput = document.getElementById("totpCode") as HTMLInputElement | null;
          if (!codeInput) return;
          const code = codeInput.value.trim();

          loginError.classList.add("hidden");

          try {
            const res = await fetch("/api/auth/verify", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ code }),
            });

            const data = await res.json();

            if (res.ok && data.ok) {
              window.location.href = "/admin";
            } else if (data.error === "invalid_code") {
              loginError.textContent = "Invalid code. Try again with the current 6-digit code from your authenticator app.";
              loginError.classList.remove("hidden");
            } else if (data.error === "setup_required") {
              window.location.href = "/auth/setup";
            } else {
              loginError.textContent = data.error || "Verification failed. Try again.";
              loginError.classList.remove("hidden");
            }
          } catch (err) {
            loginError.textContent = "Connection error. Is the server running?";
            loginError.classList.remove("hidden");
            console.error("[TOTP/Login] Verify failed:", err);
          }
        });
      })();
    </script>
  </body>
</html>
