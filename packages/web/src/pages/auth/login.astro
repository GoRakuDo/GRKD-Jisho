---
import "../../styles/globals.css";

const errorMessages: Record<string, string> = {
  guild_required: "You must be a member of the GRKD-Jisho Discord server to access this admin panel.",
  admin_required: "You need administrator or manager permissions in the Discord server to access this admin panel.",
  oauth_failed: "Authentication with Discord failed. Please try again.",
  session_expired: "Your session has expired. Please log in again.",
};

const error = Astro.url.searchParams.get("error");
const errorMessage = error ? errorMessages[error] ?? "An unexpected error occurred." : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login — GRKD-Jisho Admin</title>
  </head>
  <body class="bg-porcelain-50 min-h-dvh flex flex-col items-center justify-center font-grkd-sans">
    <main class="w-full max-w-2xl px-6 flex flex-col items-center">
      <div class="mb-12 text-center">
        <h1 class="text-display font-bold text-graphite-800 tracking-tight mb-4">GRKD-Jisho Admin</h1>
        <p class="text-body text-graphite-650 max-w-lg mx-auto">
          The central command for the Indonesian-Japanese dictionary bot. 
          Manage your data sources and refine learning experiences.
        </p>
      </div>

      <div class="w-full max-w-md bg-porcelain-100 border border-graphite-180 rounded-panel p-8 shadow-sm">
        <div class="mb-8">
          <h2 class="text-heading-sm font-semibold text-graphite-800 mb-6">Quick Access Guide</h2>
          <ol class="space-y-4 text-body-sm text-graphite-650">
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-royal-blue-100 text-royal-blue-700 flex items-center justify-center text-xs font-semibold border border-royal-blue-600">1</span>
              <span>Sign in with your Discord account</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-royal-blue-100 text-royal-blue-700 flex items-center justify-center text-xs font-semibold border border-royal-blue-600">2</span>
              <span>Authorize the admin dashboard</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="flex-shrink-0 w-5 h-5 rounded-full bg-royal-blue-100 text-royal-blue-700 flex items-center justify-center text-xs font-semibold border border-royal-blue-600">3</span>
              <span>Manage dictionaries and settings</span>
            </li>
          </ol>
        </div>

        {errorMessage && (
          <div class="bg-danger-100 text-danger-600 text-body-sm rounded-button px-4 py-3 mb-6">
            {errorMessage}
          </div>
        )}

        <a
          href="/api/auth/authorize"
          class="inline-flex items-center justify-center w-full bg-royal-blue-600 text-porcelain-50 border border-royal-blue-700 hover:bg-royal-blue-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-royal-blue-600 focus-visible:ring-offset-2 focus-visible:ring-offset-porcelain-100 rounded-button px-6 py-3 text-body-sm font-semibold transition-colors no-underline shadow-sm"
        >
          Sign in with Discord
        </a>
      </div>

      <footer class="mt-16 text-center text-caption text-graphite-500">
        <p class="mb-1">GRKD-Jisho Admin &bull; v0.1.0</p>
        <p class="opacity-60">Powered by GoRakuDo</p>
      </footer>
    </main>
  </body>
</html>
