---
import "../../styles/globals.css";
import { WEBUI_CONFIG } from "../../config/webui";

const loginUi = WEBUI_CONFIG.login;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{loginUi.title}</title>
  </head>
  <body class={loginUi.shell.bodyClass}>
    <main class={loginUi.shell.mainClass}>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_12%_18%,oklch(92%_0.08_262/0.32),transparent_28%),radial-gradient(circle_at_86%_80%,oklch(94.5%_0.04_95/0.45),transparent_28%),linear-gradient(180deg,oklch(97%_0.012_95),oklch(95%_0.01_95))]" />

      <section class={loginUi.shell.stageClass}>
        <div class={loginUi.shell.shellClass}>
          <aside class="relative flex flex-col justify-between gap-10 overflow-hidden bg-[linear-gradient(160deg,oklch(43%_0.19_262),oklch(38%_0.18_251))] px-7 py-8 text-porcelain-50 sm:px-9 sm:py-10 lg:px-10 lg:py-12">
            <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_18%_18%,oklch(96%_0.025_262/0.18),transparent_28%),radial-gradient(circle_at_82%_82%,oklch(94%_0.06_95/0.12),transparent_26%)]" />

            <div class="relative space-y-8 max-w-lg">
              <div class="flex items-center gap-3 text-caption uppercase tracking-[0.34em] text-porcelain-50/75">
                <span class="h-2.5 w-2.5 rounded-full bg-royal-blue-100 shadow-[0_0_0_6px_oklch(96%_0.025_262/0.1)]" />
                {loginUi.hero.kicker}
              </div>

              <div class="space-y-5">
                <p class="text-body-sm uppercase tracking-[0.28em] text-porcelain-50/70">{loginUi.hero.product}</p>
                <h1 class="max-w-md text-[clamp(2.4rem,5vw,4.75rem)] leading-[0.94] font-bold tracking-[-0.05em] text-porcelain-50">
                  {loginUi.hero.headline}
                  <span class="block text-royal-blue-100">{loginUi.hero.accent}</span>
                </h1>
                <p class="max-w-md text-body text-porcelain-50/78">
                  {loginUi.hero.description}
                </p>
              </div>

              <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-2">
                <article class="rounded-panel border border-porcelain-50/14 bg-porcelain-50/8 p-5 backdrop-blur-sm xl:min-h-[148px]">
                  <p class="text-caption uppercase tracking-[0.26em] text-porcelain-50/60">{loginUi.steps.stepLabels[0]}</p>
                  <p class="mt-3 text-body text-porcelain-50/88">{loginUi.steps.setup[0]}</p>
                </article>
                <article class="rounded-panel border border-porcelain-50/14 bg-porcelain-50/8 p-5 backdrop-blur-sm xl:min-h-[148px]">
                  <p class="text-caption uppercase tracking-[0.26em] text-porcelain-50/60">{loginUi.steps.stepLabels[1]}</p>
                  <p class="mt-3 text-body text-porcelain-50/88">{loginUi.steps.setup[1]}</p>
                </article>
                <article class="rounded-panel border border-porcelain-50/14 bg-porcelain-50/8 p-5 backdrop-blur-sm xl:col-span-2 xl:min-h-[120px]">
                  <p class="text-caption uppercase tracking-[0.26em] text-porcelain-50/60">{loginUi.steps.stepLabels[2]}</p>
                  <p class="mt-3 text-body text-porcelain-50/88">{loginUi.steps.setup[2]}</p>
                </article>
              </div>
            </div>

            <div class="relative flex flex-col gap-4 rounded-panel border border-porcelain-50/12 bg-porcelain-50/8 p-5 backdrop-blur-sm">
              <div class="flex items-center justify-between gap-4">
                <span class="text-caption uppercase tracking-[0.3em] text-porcelain-50/60">{loginUi.hero.accessModeLabel}</span>
                <span class="rounded-full border border-royal-blue-100/35 bg-royal-blue-100/12 px-3 py-1 text-caption font-semibold text-royal-blue-50">
                  {loginUi.hero.accessModeBadge}
                </span>
              </div>
              <p class="max-w-sm text-body-sm text-porcelain-50/80">{loginUi.hero.accessModeCopy}</p>
            </div>
          </aside>

          <section class="relative flex min-h-[560px] flex-col justify-center gap-6 px-5 py-8 sm:px-8 sm:py-10 lg:px-10 lg:py-12">
            <div id="loading" class={loginUi.layout.loadingClass}>
              <span class="h-2.5 w-2.5 animate-pulse rounded-full bg-royal-blue-600" />
              {loginUi.auth.loading}
            </div>

            <div id="authContainer" class={loginUi.layout.authCardClass}>
              <div class="flex flex-wrap items-start justify-between gap-4 border-b border-graphite-180 pb-5">
                <div class="space-y-2">
                  <p class="text-caption uppercase tracking-[0.3em] text-graphite-500">{loginUi.auth.laneLabel}</p>
                  <h2 id="modeTitle" class="text-heading-md font-semibold tracking-tight text-graphite-900">{loginUi.auth.returningTitle}</h2>
                  <p id="modeCopy" class="max-w-2xl text-body-sm text-graphite-650">{loginUi.auth.returningCopy}</p>
                </div>
                <span id="modeBadge" class="rounded-full border border-royal-blue-100 bg-royal-blue-50 px-3 py-1 text-caption font-semibold text-royal-blue-700">
                  {loginUi.auth.returningBadge}
                </span>
              </div>

              <div id="setupGuide" class="hidden mt-6 rounded-panel border border-graphite-180 bg-porcelain-100 p-5">
                <p class="text-body-sm font-semibold text-graphite-900">{loginUi.auth.setupGuideTitle}</p>
                <div class="mt-4 grid gap-4 md:grid-cols-3">
                  <article class="rounded-panel border border-graphite-180 bg-porcelain-50 p-5">
                    <p class="text-caption uppercase tracking-[0.26em] text-graphite-500">{loginUi.steps.stepLabels[0]}</p>
                    <p class="mt-2 text-body-sm text-graphite-650">{loginUi.auth.setupGuideSteps[0]}</p>
                  </article>
                  <article class="rounded-panel border border-graphite-180 bg-porcelain-50 p-5">
                    <p class="text-caption uppercase tracking-[0.26em] text-graphite-500">{loginUi.steps.stepLabels[1]}</p>
                    <p class="mt-2 text-body-sm text-graphite-650">{loginUi.auth.setupGuideSteps[1]}</p>
                  </article>
                  <article class="rounded-panel border border-graphite-180 bg-porcelain-50 p-5">
                    <p class="text-caption uppercase tracking-[0.26em] text-graphite-500">{loginUi.steps.stepLabels[2]}</p>
                    <p class="mt-2 text-body-sm text-graphite-650">{loginUi.auth.setupGuideSteps[2]}</p>
                  </article>
                </div>
              </div>

              <div id="loginGuide" class="mt-4 rounded-panel border border-graphite-180 bg-porcelain-100 p-4">
                <div class="flex flex-col gap-2 md:flex-row md:gap-3">
                  <div class="flex flex-1 items-start gap-2">
                    <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-royal-blue-600 text-[11px] font-bold text-porcelain-50">1</span>
                    <p class="text-[13px] text-graphite-650">{loginUi.auth.loginGuideSteps[0]}</p>
                  </div>
                  <div class="flex flex-1 items-start gap-2">
                    <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-royal-blue-600 text-[11px] font-bold text-porcelain-50">2</span>
                    <p class="text-[13px] text-graphite-650">{loginUi.auth.loginGuideSteps[1]}</p>
                  </div>
                  <div class="flex flex-1 items-start gap-2">
                    <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-royal-blue-600 text-[11px] font-bold text-porcelain-50">3</span>
                    <p class="text-[13px] text-graphite-650">{loginUi.auth.loginGuideSteps[2]}</p>
                  </div>
                </div>
              </div>

              <div id="qrSection" class={loginUi.layout.qrCardClass}>
                <div class={loginUi.layout.qrWrapClass}>
                  <img id="qrImage" src="" alt="TOTP QR Code" class="aspect-square w-full rounded-[14px] bg-porcelain-50 object-contain p-1.5" />
                </div>
                <p class="mt-4 text-center text-caption text-graphite-500">{loginUi.auth.qrHelp}</p>
                <code id="manualSecret" class={loginUi.layout.manualKeyClass}></code>
              </div>

              <form id="loginForm" class={loginUi.layout.formClass}>
                <div>
                  <label for="totpCode" class="mb-1.5 block text-body-sm font-semibold text-graphite-800">{loginUi.auth.codeLabel}</label>
                  <input
                    id="totpCode"
                    type="text"
                    inputmode="numeric"
                    pattern="[0-9]{6}"
                    maxlength="6"
                    autocomplete="one-time-code"
                    placeholder={loginUi.auth.codePlaceholder}
                    class="w-full rounded-button border border-graphite-250 bg-porcelain-50 px-4 py-3.5 text-center font-grkd-mono text-heading-sm font-bold tracking-[0.45em] text-graphite-900 placeholder:text-graphite-400 focus-visible:border-royal-blue-600 focus-visible:ring-2 focus-visible:ring-royal-blue-100"
                  />
                </div>

                <button
                  id="submitButton"
                  type="submit"
                  class="w-full rounded-button border border-royal-blue-700 bg-royal-blue-600 px-6 py-3.5 text-body-sm font-semibold text-porcelain-50 shadow-sm transition-colors hover:bg-royal-blue-700 focus-visible:ring-2 focus-visible:ring-royal-blue-100 disabled:cursor-not-allowed disabled:opacity-60"
                >
                  {loginUi.auth.submitLogin}
                </button>

                <p id="loginError" class="hidden text-center text-body-sm text-danger-600"></p>
              </form>

              <p class="mt-6 text-center text-caption text-graphite-500">
                <span set:html={loginUi.auth.resetHint} />
              </p>
            </div>
          </section>
        </div>
      </section>

      <footer class={loginUi.shell.footerClass}>
        <p class="mb-1">{loginUi.shell.footerTitle} &bull; {loginUi.shell.footerSuffix}</p>
        <p class="opacity-60">{loginUi.shell.footerPoweredBy}</p>
      </footer>
    </main>

    <script>
      import { WEBUI_CONFIG } from "../../config/webui";

      const loginUi = WEBUI_CONFIG.login;

      (async () => {
        const loading = document.getElementById("loading");
        const authContainer = document.getElementById("authContainer");
        const setupGuide = document.getElementById("setupGuide");
        const qrSection = document.getElementById("qrSection");
        const qrImage = document.getElementById("qrImage");
        const manualSecret = document.getElementById("manualSecret");
        const loginGuide = document.getElementById("loginGuide");
        const submitButton = document.getElementById("submitButton");
        const loginForm = document.getElementById("loginForm");
        const loginError = document.getElementById("loginError");
        const modeTitle = document.getElementById("modeTitle");
        const modeBadge = document.getElementById("modeBadge");
        const modeCopy = document.getElementById("modeCopy");

        if (!loading || !authContainer || !setupGuide || !qrSection || !qrImage || !manualSecret || !loginGuide || !submitButton || !loginForm || !loginError || !modeTitle || !modeBadge || !modeCopy) return;

        let setupRequired = false;

        try {
          const statusRes = await fetch("/api/auth/status");
          const data = await statusRes.json();

          setupRequired = Boolean(data.setupRequired);
          if (setupRequired) {
            const setupRes = await fetch("/api/auth/setup");
            const setupDataPayload = await setupRes.json();

            if (setupDataPayload.alreadySetup) {
              setupRequired = false;
            } else if (setupDataPayload.qrDataUrl && setupDataPayload.secret) {
              qrImage.setAttribute("src", setupDataPayload.qrDataUrl);
              manualSecret.textContent = setupDataPayload.secret;
              setupGuide.classList.remove("hidden");
              loginGuide.classList.add("hidden");
              qrSection.classList.remove("hidden");
              modeTitle.textContent = loginUi.auth.setupTitle;
              modeBadge.textContent = loginUi.auth.setupBadge;
              modeCopy.textContent = loginUi.auth.setupCopy;
            } else {
              throw new Error("Failed to load setup payload");
            }
          }

          if (!setupRequired) {
            setupGuide.classList.add("hidden");
            qrSection.classList.add("hidden");
            loginGuide.classList.remove("hidden");
            submitButton.textContent = loginUi.auth.submitLogin;
            modeTitle.textContent = loginUi.auth.returningTitle;
            modeBadge.textContent = loginUi.auth.returningBadge;
            modeCopy.textContent = loginUi.auth.returningCopy;
          } else {
            submitButton.textContent = loginUi.auth.submitSetup;
          }

          loading.classList.add("hidden");
          authContainer.classList.remove("hidden");
        } catch (err) {
          loading.innerHTML = loginUi.auth.loadingFailed;
          console.error("[TOTP/Login] Status check failed:", err);
          return;
        }

        loginForm.addEventListener("submit", async (e) => {
          e.preventDefault();

          const codeInput = document.getElementById("totpCode") as HTMLInputElement | null;
          if (!codeInput) return;
          const code = codeInput.value.trim();

          loginError.classList.add("hidden");
          const previousLabel = submitButton.textContent || loginUi.auth.submitLogin;
          submitButton.setAttribute("disabled", "true");
          submitButton.textContent = previousLabel === loginUi.auth.submitSetup ? loginUi.auth.submitBusySetup : loginUi.auth.submitBusyLogin;

          try {
            const res = await fetch("/api/auth/verify", {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ code }),
            });

            const data = await res.json();

            if (res.ok && data.ok) {
              window.location.href = "/admin";
            } else if (data.error === "invalid_code") {
              loginError.textContent = loginUi.auth.invalidCode;
              loginError.classList.remove("hidden");
            } else if (data.error === "setup_required") {
              window.location.href = loginUi.auth.setupRequiredRedirect;
            } else {
              loginError.textContent = data.error || loginUi.auth.verificationFailed;
              loginError.classList.remove("hidden");
            }
          } catch (err) {
            loginError.textContent = loginUi.auth.connectionError;
            loginError.classList.remove("hidden");
            console.error("[TOTP/Login] Verify failed:", err);
          } finally {
            submitButton.removeAttribute("disabled");
            submitButton.textContent = setupRequired ? loginUi.auth.submitSetup : loginUi.auth.submitLogin;
          }
        });
      })();
    </script>
  </body>
</html>
